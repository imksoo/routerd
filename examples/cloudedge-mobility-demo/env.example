# Copy this file to ./env and fill every placeholder before running scripts.
# Do not commit ./env.

# Local tools
ROUTERD_BIN=/usr/local/sbin/routerd
ROUTERCTL_BIN=/usr/local/sbin/routerctl
SSH_KEY_FILE=/path/to/demo_ssh_key
SSH_USER=ubuntu
CLIENT_SSH_USER=ubuntu
EVIDENCE_ROOT=./evidence

# Shared federation secret. Generate locally, for example:
#   openssl rand -hex 32
EVENT_HMAC_SECRET_VALUE=<GENERATE_AND_KEEP_OUT_OF_GIT>
EVENT_HMAC_SECRET_FILE=/usr/local/etc/routerd/secrets/eventd-cloudedge.key

# Router SSH targets. Use DNS names or public IPs in your private env file.
ONPREM_ROUTER_SSH_HOST=<ONPREM_ROUTER_SSH_HOST>
AWS_ROUTER_A_SSH_HOST=<AWS_ROUTER_A_SSH_HOST>
AWS_ROUTER_B_SSH_HOST=<AWS_ROUTER_B_SSH_HOST>
AZURE_ROUTER_SSH_HOST=<AZURE_ROUTER_SSH_HOST>
OCI_ROUTER_SSH_HOST=<OCI_ROUTER_SSH_HOST>

# Client SSH targets, reachable from their local router or the operator host.
ONPREM_CLIENT_SSH_HOST=10.77.60.10
AWS_CLIENT_SSH_HOST=10.77.60.11
AZURE_CLIENT_SSH_HOST=10.77.60.12
OCI_CLIENT_SSH_HOST=10.77.60.13

# WireGuard public keys and reachable endpoints. Private keys live only on nodes.
ONPREM_WG_PUBLIC_KEY=<ONPREM_WG_PUBLIC_KEY>
AWS_ROUTER_A_WG_PUBLIC_KEY=<AWS_ROUTER_A_WG_PUBLIC_KEY>
AWS_ROUTER_B_WG_PUBLIC_KEY=<AWS_ROUTER_B_WG_PUBLIC_KEY>
AZURE_WG_PUBLIC_KEY=<AZURE_WG_PUBLIC_KEY>
OCI_WG_PUBLIC_KEY=<OCI_WG_PUBLIC_KEY>

ONPREM_WG_ENDPOINT=<ONPREM_WG_ENDPOINT_HOST_PORT>
AWS_ROUTER_A_WG_ENDPOINT=<AWS_ROUTER_A_WG_ENDPOINT_HOST_PORT>
AWS_ROUTER_B_WG_ENDPOINT=<AWS_ROUTER_B_WG_ENDPOINT_HOST_PORT>
AZURE_WG_ENDPOINT=<AZURE_WG_ENDPOINT_HOST_PORT>
OCI_WG_ENDPOINT=<OCI_WG_ENDPOINT_HOST_PORT>

# AWS provider identifiers. Use existing lab resources; scripts do not provision.
AWS_PROFILE=<AWS_PROFILE>
AWS_ACCOUNT_ID=<AWS_ACCOUNT_ID>
AWS_REGION=<AWS_REGION>
AWS_ROUTER_A_INSTANCE_ID=<AWS_ROUTER_A_INSTANCE_ID>
AWS_ROUTER_B_INSTANCE_ID=<AWS_ROUTER_B_INSTANCE_ID>
AWS_CLIENT_INSTANCE_ID=<AWS_CLIENT_INSTANCE_ID>
AWS_ROUTER_A_ENI_REF=<AWS_ROUTER_A_ENI_ID>
AWS_ROUTER_B_ENI_REF=<AWS_ROUTER_B_ENI_ID>

# Azure provider identifiers.
AZURE_SUBSCRIPTION_ID=<AZURE_SUBSCRIPTION_ID>
AZURE_RESOURCE_GROUP=<AZURE_RESOURCE_GROUP>
AZURE_ROUTER_VM_NAME=<AZURE_ROUTER_VM_NAME>
AZURE_CLIENT_VM_NAME=<AZURE_CLIENT_VM_NAME>
AZURE_ROUTER_NIC_REF=<AZURE_ROUTER_NIC_RESOURCE_ID>
AZURE_ROUTER_NIC_NAME=<AZURE_ROUTER_NIC_NAME>
AZURE_REGION=<AZURE_REGION>
AZURE_DEMO_IPCONFIG_NAMES=cloudedge-onprem-10-77-60-10 cloudedge-aws-10-77-60-11 cloudedge-oci-10-77-60-13

# OCI provider identifiers.
OCI_CONFIG_FILE=/home/user/.oci/config
OCI_PROFILE=<OCI_PROFILE>
OCI_REGION=<OCI_REGION>
OCI_COMPARTMENT_REF=<OCI_COMPARTMENT_OCID>
OCI_ROUTER_INSTANCE_REF=<OCI_ROUTER_INSTANCE_OCID>
OCI_CLIENT_INSTANCE_REF=<OCI_CLIENT_INSTANCE_OCID>
OCI_ROUTER_VNIC_REF=<OCI_ROUTER_VNIC_OCID>
OCI_DEMO_PRIVATE_IP_REFS=<SPACE_SEPARATED_OCI_PRIVATE_IP_OCIDS_TO_DELETE_ON_RESET>

# Demo addresses. These are intentionally non-secret logical lab addresses.
ONPREM_CLIENT_IP=10.77.60.10
AWS_CLIENT_IP=10.77.60.11
AZURE_CLIENT_IP=10.77.60.12
OCI_CLIENT_IP=10.77.60.13
