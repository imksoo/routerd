    argv.extend(args)
    argv.extend(["--output", "json"])
    return run_json(argv)


def address_in_prefix(address, prefix):
    try:
        net = ipaddress.ip_network(prefix, strict=False)
        cidr = ipaddress.ip_network(address, strict=False)
    except Exception:
        return False
    return cidr.version == 4 and cidr.prefixlen == 32 and cidr.network_address in net


def azure_resource_name(ref):
    ref = (ref or "").strip().rstrip("/")
    if not ref:
        return ""
    return ref.split("/")[-1]


def first_non_empty(*values):
    for value in values:
        value = (value or "").strip()
        if value:
            return value
    return ""


def aws_eni_instance_metadata(region, subnet):
    """Return dict of ENI ID -> instance metadata for all instances in the subnet."""
    try:
        doc = aws_cli(region, ["ec2", "describe-instances",
                               "--filters",
                               "Name=subnet-id,Values=" + subnet])
        metadata = {}
        for res in doc.get("Reservations") or []:
            for inst in res.get("Instances") or []:
                instance_id = inst.get("InstanceId", "")
                state = inst.get("State", {}).get("Name", "")
                for nic in inst.get("NetworkInterfaces") or []:
                    eni = nic.get("NetworkInterfaceId", "")
                    if eni:
                        metadata[eni] = {"resourceRef": instance_id, "instanceState": state}
        return metadata
    except Exception as exc:
        raise RuntimeError("AWS instance metadata inventory failed: " + str(exc)) from exc


def aws_route_table_captured_addresses(region, route_table_ref, self_nic, prefix):
    if not route_table_ref or not self_nic:
        return []
    try:
        doc = aws_cli(region, ["ec2", "describe-route-tables",
                               "--route-table-ids", route_table_ref])
    except Exception:
        return []
    out = []
    for table in doc.get("RouteTables") or []:
        for route in table.get("Routes") or []:
            address = route.get("DestinationCidrBlock", "")
            if route.get("NetworkInterfaceId", "") != self_nic:
                continue
            if not address_in_prefix(address, prefix):
                continue
            out.append(address)
    return sorted(set(out))


def aws_inventory(spec):
    target = spec.get("target") or {}
    region = target.get("region") or os.environ.get("AWS_DEFAULT_REGION", "")
    strategy = (spec.get("strategy") or "").strip()
    prefix = (spec.get("prefix") or "").strip()
    route_table_ref = (spec.get("routeTableRef") or target.get("routeTableRef") or "").strip()
    self_nic = (spec.get("selfNicRef", "").strip()
                or os.environ.get("ROUTERD_PROVIDER_INVENTORY_SELF_NIC_REF", "").strip()
                or os.environ.get("AWS_SELF_ENI_REF", "").strip())
    subnet = (spec.get("subnetRef") or "").strip()
    self_private_ips = []
    self_forwarding_enabled = None
    if not self_nic:
        local_ips = local_ipv4s() or [ip for ip in [aws_imds_ipv4()] if ip]
        imds_self = aws_imds_self_interface(local_ips)
        if imds_self:
            self_nic = imds_self.get("nicRef", "")
            subnet = subnet or imds_self.get("subnetRef", "")
            self_private_ips = imds_self.get("privateIPs") or []
        if not local_ips:
            raise ValueError("AWS selfNicRef is empty and no local private IP could be discovered")
    if not self_nic:
        local_ips = local_ipv4s() or [ip for ip in [aws_imds_ipv4()] if ip]
        self_doc = aws_cli(region, ["ec2", "describe-network-interfaces", "--filters", "Name=addresses.private-ip-address,Values=" + ",".join(local_ips)])
        interfaces = self_doc.get("NetworkInterfaces") or []
        if subnet:
            interfaces = [nic for nic in interfaces if nic.get("SubnetId") == subnet]
        if not interfaces:
            raise ValueError("AWS self network interface could not be resolved from local IPs")
        interfaces.sort(key=lambda nic: nic.get("NetworkInterfaceId", ""))
        self_nic = interfaces[0].get("NetworkInterfaceId", "")
        subnet = subnet or interfaces[0].get("SubnetId", "")
        self_private_ips = [rec.get("PrivateIpAddress", "") for rec in interfaces[0].get("PrivateIpAddresses") or [] if rec.get("PrivateIpAddress")]
        if "SourceDestCheck" in interfaces[0]:
            self_forwarding_enabled = not bool(interfaces[0].get("SourceDestCheck"))
    if not subnet or not self_private_ips or self_forwarding_enabled is None:
        self_doc = aws_cli(region, ["ec2", "describe-network-interfaces", "--network-interface-ids", self_nic])
        interfaces = self_doc.get("NetworkInterfaces") or []
        if not interfaces:
            raise ValueError("AWS self network interface was not found")
        subnet = subnet or interfaces[0].get("SubnetId", "")
        self_private_ips = self_private_ips or [rec.get("PrivateIpAddress", "") for rec in interfaces[0].get("PrivateIpAddresses") or [] if rec.get("PrivateIpAddress")]
        if "SourceDestCheck" in interfaces[0]:
            self_forwarding_enabled = not bool(interfaces[0].get("SourceDestCheck"))
    if not subnet:
        raise ValueError("AWS subnetRef could not be inferred from self NIC")
    eni_metadata = aws_eni_instance_metadata(region, subnet)
    doc = aws_cli(region, ["ec2", "describe-network-interfaces", "--filters", "Name=subnet-id,Values=" + subnet])
    ips = []
    self_resource_ref = ""
    for nic in doc.get("NetworkInterfaces") or []:
        nic_ref = nic.get("NetworkInterfaceId", "")
        subnet_ref = nic.get("SubnetId", subnet)
        tags = {item.get("Key", ""): item.get("Value", "") for item in nic.get("TagSet") or [] if item.get("Key")}
        metadata = (eni_metadata or {}).get(nic_ref, {})
        resource_ref = metadata.get("resourceRef", "")
        if nic_ref == self_nic and resource_ref:
            self_resource_ref = resource_ref
        instance_state = metadata.get("instanceState", "")
        resource_type = "instance-nic"
        if nic_ref == self_nic or str(tags.get("role", "")).lower() == "router":
            resource_type = "router-nic"
        for rec in nic.get("PrivateIpAddresses") or []:
            address = rec.get("PrivateIpAddress", "")
            if not address:
                continue
            entry = {
                "address": address,
                "nicRef": nic_ref,
                "subnetRef": subnet_ref,
                "resourceType": resource_type,
                "primary": bool(rec.get("Primary")),
                "tags": tags,
            }
            if resource_ref:
                entry["resourceRef"] = resource_ref
            if instance_state:
                entry["instanceState"] = instance_state
            ips.append(entry)
    self_info = {"nicRef": self_nic, "subnetRef": subnet, "privateIPs": sorted(set(self_private_ips))}
    if strategy == "route-table":
        captured = aws_route_table_captured_addresses(region, route_table_ref, self_nic, prefix)
        if captured:
            self_info["capturedAddresses"] = captured
    if self_resource_ref:
        self_info["resourceRef"] = self_resource_ref
        self_info["resourceType"] = "router-nic"
    if self_forwarding_enabled is not None:
        self_info["forwardingEnabled"] = bool(self_forwarding_enabled)
    return self_info, ips


def azure_nic_vm_metadata(resource_group):
    """Return dict of NIC resource ID -> VM metadata."""
    try:
        vms = az_cli(["vm", "list", "--resource-group", resource_group, "--show-details"])
        metadata = {}
        for vm in vms or []:
            vm_id = vm.get("id", "")
            power_state = vm.get("powerState", "")
            for nic_ref in (vm.get("networkProfile") or {}).get("networkInterfaces") or []:
                nic_id = nic_ref.get("id", "")
                if nic_id:
                    metadata[nic_id] = {"resourceRef": vm_id, "powerState": power_state}
        return metadata
    except Exception as exc:
        raise RuntimeError("Azure VM metadata inventory failed: " + str(exc)) from exc


def azure_inventory(spec):
    target = spec.get("target") or {}
    self_nic = spec.get("selfNicRef", "").strip()
    resource_group = target.get("resourceGroup", "").strip()
    subnet = (spec.get("subnetRef") or "").strip()
    strategy = (spec.get("strategy") or "").strip()
    prefix = (spec.get("prefix") or "").strip()
    route_table_name = first_non_empty(target.get("routeTableName", ""), azure_resource_name(spec.get("routeTableRef") or target.get("routeTableRef") or ""))
    next_hop_ip = (target.get("nextHopIPAddress") or "").strip()
    if not resource_group:
        if self_nic:
            self_doc = az_cli(["network", "nic", "show", "--ids", self_nic])
            resource_group = self_doc.get("resourceGroup", "")
        if not resource_group:
            raise ValueError("Azure resourceGroup is required for segment inventory")
    nics = az_cli(["network", "nic", "list", "--resource-group", resource_group])
    self_doc = {}
    self_forwarding_enabled = None
    local_ips = local_ipv4s() or azure_imds_ipv4s()
    if self_nic:
        self_doc = az_cli(["network", "nic", "show", "--ids", self_nic])
    else:
        for nic in nics or []:
            for cfg in nic.get("ipConfigurations") or []:
                address = cfg.get("privateIPAddress") or cfg.get("privateIpAddress") or ""
                if address in local_ips:
                    self_doc = nic
                    self_nic = nic.get("id", "")
                    break
            if self_nic:
                break
    if not self_nic:
        raise ValueError("Azure self NIC could not be resolved from local IPs")
    if "enableIPForwarding" in self_doc:
        self_forwarding_enabled = bool(self_doc.get("enableIPForwarding"))
    if not subnet:
        configs = self_doc.get("ipConfigurations") or []
        if configs:
            subnet = ((configs[0].get("subnet") or {}).get("id") or "")
    if not subnet:
        raise ValueError("Azure subnetRef could not be inferred from self NIC")
    self_private_ips = []
    for cfg in self_doc.get("ipConfigurations") or []:
        address = cfg.get("privateIPAddress") or cfg.get("privateIpAddress") or ""
        if address:
            self_private_ips.append(address)
    nic_metadata = azure_nic_vm_metadata(resource_group)
    ips = []
    self_resource_ref = ""
    for nic in nics or []:
        nic_ref = nic.get("id", "")
        tags = nic.get("tags") or {}
        metadata = (nic_metadata or {}).get(nic_ref, {})
        resource_ref = metadata.get("resourceRef", "")
        if nic_ref == self_nic and resource_ref:
            self_resource_ref = resource_ref
        vm_state = metadata.get("powerState", "")
        instance_state = ""
        if vm_state == "VM running":
            instance_state = "running"
        elif vm_state:
            instance_state = "stopped"
        resource_type = "instance-nic"
        if nic_ref == self_nic or str(tags.get("role", "")).lower() == "router":
            resource_type = "router-nic"
        for cfg in nic.get("ipConfigurations") or []:
            subnet_ref = ((cfg.get("subnet") or {}).get("id") or "")
            if subnet_ref != subnet:
                continue
            address = cfg.get("privateIPAddress") or cfg.get("privateIpAddress") or ""
            if not address:
                continue
            entry = {
                "address": address,
                "nicRef": nic_ref,
                "subnetRef": subnet_ref,
                "resourceType": resource_type,
                "primary": bool(cfg.get("primary")),
                "tags": tags,
            }
            if resource_ref:
                entry["resourceRef"] = resource_ref
            if instance_state:
                entry["instanceState"] = instance_state
            ips.append(entry)
    self_info = {"nicRef": self_nic, "subnetRef": subnet, "privateIPs": sorted(set(self_private_ips))}
    if strategy == "route-table" and route_table_name and next_hop_ip:
        try:
            routes = az_cli(["network", "route-table", "route", "list",
                             "--resource-group", resource_group,
                             "--route-table-name", route_table_name])
            captured = []
            for route in routes or []:
                address = route.get("addressPrefix") or route.get("address_prefix") or ""
                hop_type = route.get("nextHopType") or route.get("next_hop_type") or ""
                hop_ip = route.get("nextHopIpAddress") or route.get("next_hop_ip_address") or ""
                if hop_type and hop_type != "VirtualAppliance":
                    continue
                if hop_ip != next_hop_ip:
                    continue
                if not address_in_prefix(address, prefix):
                    continue
                captured.append(address)
            if captured:
                self_info["capturedAddresses"] = sorted(set(captured))
        except Exception:
            pass
    if self_resource_ref:
        self_info["resourceRef"] = self_resource_ref
        self_info["resourceType"] = "router-nic"
    if self_forwarding_enabled is not None:
        self_info["forwardingEnabled"] = bool(self_forwarding_enabled)
    return self_info, ips


def flatten_oci_tags(rec):
    tags = {}
    for key, value in (rec.get("freeform-tags") or {}).items():
        tags[str(key)] = str(value)
    for namespace, values in (rec.get("defined-tags") or {}).items():
        if isinstance(values, dict):
            for key, value in values.items():
                tags[str(namespace) + "." + str(key)] = str(value)
    return tags


def oci_vnic_instance_metadata(region, compartment):
    """Return dict of VNIC ID -> instance metadata."""
    try:
        attachments = oci_cli(region, ["compute", "vnic-attachment", "list",
                                       "--compartment-id", compartment, "--all"])
        vnic_to_instance = {}
        for att in attachments.get("data") or []:
            vid = att.get("vnic-id", "")
            iid = att.get("instance-id", "")
            if vid and iid:
                vnic_to_instance[vid] = iid
        instances = oci_cli(region, ["compute", "instance", "list",
                                     "--compartment-id", compartment, "--all"])
        instance_states = {}
        for inst in instances.get("data") or []:
            instance_states[inst.get("id", "")] = inst.get("lifecycle-state", "")
        vnic_metadata = {}
        for vid, iid in vnic_to_instance.items():
            state = instance_states.get(iid, "")
            item = {"resourceRef": iid}
            if state == "RUNNING":
                item["instanceState"] = "running"
            elif state:
                item["instanceState"] = "stopped"
            vnic_metadata[vid] = item
        return vnic_metadata
    except Exception:
        return None


def oci_inventory(spec):
    target = spec.get("target") or {}
    region = target.get("region") or os.environ.get("OCI_REGION", "")
    self_nic = spec.get("selfNicRef", "").strip()
    subnet = (spec.get("subnetRef") or "").strip()
    if not self_nic:
        self_nic = (os.environ.get("ROUTERD_PROVIDER_INVENTORY_SELF_NIC_REF", "").strip()
                    or os.environ.get("OCI_SELF_VNIC_REF", "").strip())
    if not self_nic:
        self_nic = oci_imds_vnic_id()
    if not self_nic:
        raise ValueError("OCI self VNIC could not be resolved from IMDS")
    self_private_ips = []
    self_doc = oci_cli(region, ["network", "vnic", "get", "--vnic-id", self_nic])
    self_data = self_doc.get("data") or {}
    if not subnet:
        subnet = (self_data.get("subnet-id") or "")
    if not subnet:
        raise ValueError("OCI subnetRef could not be inferred from self VNIC")
    compartment = self_data.get("compartment-id", "")
    vnic_metadata = oci_vnic_instance_metadata(region, compartment) if compartment else None
    doc = oci_cli(region, ["network", "private-ip", "list", "--subnet-id", subnet, "--all"])
    ips = []
    self_resource_ref = ""
    for rec in doc.get("data") or []:
        address = rec.get("ip-address", "")
        if not address:
            continue
        vnic_id = rec.get("vnic-id", "")
        if vnic_id == self_nic:
            self_private_ips.append(address)
        metadata = (vnic_metadata or {}).get(vnic_id, {})
        resource_ref = metadata.get("resourceRef", "")
        if vnic_id == self_nic and resource_ref:
            self_resource_ref = resource_ref
        instance_state = metadata.get("instanceState", "")
        tags = flatten_oci_tags(rec)
        resource_type = "instance-nic"
        if vnic_id == self_nic or str(tags.get("role", "")).lower() == "router":
            resource_type = "router-nic"
        entry = {
            "address": address,
            "nicRef": vnic_id,
            "subnetRef": rec.get("subnet-id", subnet),
            "resourceType": resource_type,
            "primary": bool(rec.get("is-primary")),
            "tags": tags,
        }
        if resource_ref:
            entry["resourceRef"] = resource_ref
        if instance_state:
            entry["instanceState"] = instance_state
        ips.append(entry)
    self_info = {"nicRef": self_nic, "subnetRef": subnet, "privateIPs": sorted(set(self_private_ips))}
    if self_resource_ref:
        self_info["resourceRef"] = self_resource_ref
        self_info["resourceType"] = "router-nic"
    if "skip-source-dest-check" in self_data:
        self_info["forwardingEnabled"] = bool(self_data.get("skip-source-dest-check"))
    return self_info, ips


def main():
    req = json.load(sys.stdin)
    spec = req.get("spec") or {}
    provider = (spec.get("provider") or "").strip().lower()
    if provider == "aws":
        self_info, ips = aws_inventory(spec)
    elif provider == "azure":
        self_info, ips = azure_inventory(spec)
    elif provider == "oci":
        self_info, ips = oci_inventory(spec)
    else:
        result("skipped", message="unsupported provider: " + provider)
        return
    result("succeeded", ips=ips, local_ips=ips, self_info=self_info)


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or "").strip()
        result("failed", error="provider CLI failed: " + (stderr or str(exc)))
    except Exception as exc:
        result("failed", error=str(exc))
