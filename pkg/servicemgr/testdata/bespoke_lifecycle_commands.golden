[vrrp-track-script-artifacts]
proves: VRRP track scripts remain explicit artifacts with executable permissions for keepalived callbacks.
commands:
  artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
  rc-service keepalived reload
forbidden:
  rc-service keepalived restart
os-matrix:
  systemd:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    systemctl reload keepalived.service
    forbidden:
      systemctl restart keepalived.service
  openrc:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    rc-service keepalived reload
    forbidden:
      rc-service keepalived restart
  rc.d:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    service keepalived reload
    forbidden:
      service keepalived restart
  nixos:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    nixos-rebuild switch

[dslite-tunnel-event-hook]
proves: DS-Lite tunnel apply remains a dataplane hook with ipip6 tunnel updates and route event publication, not a service restart.
commands:
  modprobe ip6_tunnel
  ip -6 tunnel replace ds-lite mode ipip6
  bus publish routerd.tunnel.ds-lite.up
os-matrix:
  systemd:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up
  openrc:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up
  rc.d:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up
  nixos:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up

[dhcp-event-daemon-ipc-order]
proves: DHCP event relay and fingerprint watcher keep Unix-socket IPC and daemon status warmup ordering before controller bootstrap.
commands:
  daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
  daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
  bus publish routerd.controller.bootstrap
os-matrix:
  systemd:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap
  openrc:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap
  rc.d:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap
  nixos:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap

[frr-graceful-restart-drain]
proves: FRR graceful-restart keeps config-only reloads in place and observes peers after negotiation-sensitive reloads.
commands:
  vtysh -C -f /run/routerd/frr/routerd.conf
  frr-reload.py --reload /run/routerd/frr/routerd.conf
  vtysh -c show bgp summary json
  status wait bgp graceful-restart negotiation
forbidden:
  systemctl restart frr.service
os-matrix:
  systemd:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    vtysh -c show bgp summary json
    status wait bgp graceful-restart negotiation
    forbidden:
      systemctl restart frr.service
  openrc:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    vtysh -c show bgp summary json
    status wait bgp graceful-restart negotiation
    forbidden:
      rc-service frr restart
  rc.d:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    vtysh -c show bgp summary json
    status wait bgp graceful-restart negotiation
    forbidden:
      service frr restart
  nixos:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    vtysh -c show bgp summary json
    status wait bgp graceful-restart negotiation
    forbidden:
      nixos-rebuild switch
