# Generated by TestBespokeLifecycleCommandGolden. Review every change against bespoke daemon integration behavior.

[frr-live-reload]
proves: FRR config changes run vtysh syntax check before frr-reload.py and never restart bgpd for config-only reloads.
commands:
  vtysh -C -f /run/routerd/frr/routerd.conf
  frr-reload.py --reload /run/routerd/frr/routerd.conf
forbidden:
  systemctl restart frr.service
os-matrix:
  systemd:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    forbidden:
      systemctl restart frr.service
  openrc:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    forbidden:
      rc-service frr restart
  rc.d:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    forbidden:
      service frr restart
  nixos:
    vtysh -C -f /run/routerd/frr/routerd.conf
    frr-reload.py --reload /run/routerd/frr/routerd.conf
    forbidden:
      nixos-rebuild switch

[keepalived-openrc-reload]
proves: OpenRC keepalived config changes use signal reload instead of restart when the daemon is already running.
commands:
  rc-service keepalived reload
forbidden:
  rc-service keepalived restart
os-matrix:
  systemd:
    systemctl reload keepalived.service
    forbidden:
      systemctl restart keepalived.service
  openrc:
    rc-service keepalived reload
    forbidden:
      rc-service keepalived restart
  rc.d:
    service keepalived reload
    forbidden:
      service keepalived restart
  nixos:
    nixos-rebuild switch

[keepalived-openrc-restart]
proves: OpenRC keepalived restart remains available as the fallback path and is not conflated with reload.
commands:
  rc-service keepalived restart
forbidden:
  rc-service keepalived reload
os-matrix:
  systemd:
    systemctl restart keepalived.service
    forbidden:
      systemctl reload keepalived.service
  openrc:
    rc-service keepalived restart
    forbidden:
      rc-service keepalived reload
  rc.d:
    service keepalived restart
    forbidden:
      service keepalived reload
  nixos:
    nixos-rebuild switch

[dnsmasq-sighup-reload]
proves: dnsmasq host and lease updates can be reloaded with SIGHUP through the pid file without a service restart.
commands:
  sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
forbidden:
  systemctl restart routerd-dnsmasq.service
  systemctl reload routerd-dnsmasq.service
os-matrix:
  systemd:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
    forbidden:
      systemctl restart routerd-dnsmasq.service
      systemctl reload routerd-dnsmasq.service
  openrc:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
    forbidden:
      rc-service routerd_dnsmasq restart
      rc-service routerd_dnsmasq reload
  rc.d:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
    forbidden:
      service routerd_dnsmasq restart
      service routerd_dnsmasq reload
  nixos:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"

[dhcp-client-renew-release-ipc]
proves: DHCPv4/v6 client renew and release operations stay on the Unix-socket daemon API instead of restarting client daemons.
commands:
  daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
  daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
  daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
forbidden:
  systemctl restart routerd-dhcpv4-client@wan.service
  systemctl restart routerd-dhcpv6-client@wan-pd.service
os-matrix:
  systemd:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service
  openrc:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service
  rc.d:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service
  nixos:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service

[bgpd-daemon-enable]
proves: Any BGPRouter enables bgpd in /etc/frr/daemons and enables/restarts the FRR service even when BFD is not configured.
commands:
  artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=preserve
  systemctl enable frr.service
  systemctl restart frr.service
os-matrix:
  systemd:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=preserve
    systemctl enable frr.service
    systemctl restart frr.service
  openrc:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=preserve
    rc-update add frr default
    rc-service frr restart
  rc.d:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=preserve
    sysrc frr_enable=YES
    service frr restart
  nixos:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=preserve
    nixos-rebuild switch
    nixos-rebuild switch

[bfd-daemon-enable]
proves: BGP BFD enables bgpd and bfdd in /etc/frr/daemons before the service restart needed for daemon-set changes.
commands:
  artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=yes
  systemctl enable frr.service
  systemctl restart frr.service
os-matrix:
  systemd:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=yes
    systemctl enable frr.service
    systemctl restart frr.service
  openrc:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=yes
    rc-update add frr default
    rc-service frr restart
  rc.d:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=yes
    sysrc frr_enable=YES
    service frr restart
  nixos:
    artifact-write /etc/frr/daemons zebra=yes bgpd=yes bfdd=yes
    nixos-rebuild switch
    nixos-rebuild switch

[bgp-export-policy-transit-route-map]
proves: Transit prefixes are advertised only when exportPolicy.allowedPrefixes renders an outbound permit route-map.
commands:
  render-frr ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
  render-frr route-map ROUTERD-LAN-OUT permit 10
  render-frr match ip address prefix-list ROUTERD-LAN-EXPORT
forbidden:
  render-frr route-map ROUTERD-LAN-OUT deny-only
os-matrix:
  systemd:
    render-frr ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
    render-frr route-map ROUTERD-LAN-OUT permit 10
    render-frr match ip address prefix-list ROUTERD-LAN-EXPORT
    forbidden:
      render-frr route-map ROUTERD-LAN-OUT deny-only
  openrc:
    render-frr ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
    render-frr route-map ROUTERD-LAN-OUT permit 10
    render-frr match ip address prefix-list ROUTERD-LAN-EXPORT
    forbidden:
      render-frr route-map ROUTERD-LAN-OUT deny-only
  rc.d:
    render-frr ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
    render-frr route-map ROUTERD-LAN-OUT permit 10
    render-frr match ip address prefix-list ROUTERD-LAN-EXPORT
    forbidden:
      render-frr route-map ROUTERD-LAN-OUT deny-only
  nixos:
    render-frr ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
    render-frr route-map ROUTERD-LAN-OUT permit 10
    render-frr match ip address prefix-list ROUTERD-LAN-EXPORT
    forbidden:
      render-frr route-map ROUTERD-LAN-OUT deny-only

