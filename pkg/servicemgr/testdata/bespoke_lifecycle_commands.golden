# Generated by TestBespokeLifecycleCommandGolden. Review every change against bespoke daemon integration behavior.

[dnsmasq-sighup-reload]
proves: dnsmasq host and lease updates can be reloaded with SIGHUP through the pid file without a service restart.
commands:
  sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
forbidden:
  systemctl restart routerd-dnsmasq.service
  systemctl reload routerd-dnsmasq.service
os-matrix:
  systemd:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
    forbidden:
      systemctl restart routerd-dnsmasq.service
      systemctl reload routerd-dnsmasq.service
  rc.d:
    sh -c kill -HUP "$(cat /run/routerd/dnsmasq.pid)"
    forbidden:
      service routerd_dnsmasq restart
      service routerd_dnsmasq reload

[dhcp-client-renew-release-ipc]
proves: DHCPv4/v6 client renew and release operations stay on the Unix-socket daemon API instead of restarting client daemons.
commands:
  daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
  daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
  daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
forbidden:
  systemctl restart routerd-dhcpv4-client@wan.service
  systemctl restart routerd-dhcpv6-client@wan-pd.service
os-matrix:
  systemd:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service
  rc.d:
    daemonapi POST unix:///run/routerd/dhcpv4-client/wan.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/renew
    daemonapi POST unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/commands/release
    forbidden:
      systemctl restart routerd-dhcpv4-client@wan.service
      systemctl restart routerd-dhcpv6-client@wan-pd.service

[ingress-nft-map-apply]
proves: IngressService backend rotation updates nftables dataplane state only and must not restart any daemon.
commands:
  nft -c -f /run/routerd/nat44.nft
  nft -f /run/routerd/nat44.nft
forbidden:
  systemctl restart routerd.service
  systemctl restart nftables.service
os-matrix:
  systemd:
    nft -c -f /run/routerd/nat44.nft
    nft -f /run/routerd/nat44.nft
    forbidden:
      systemctl restart routerd.service
      systemctl restart nftables.service
  rc.d:
    nft -c -f /run/routerd/nat44.nft
    nft -f /run/routerd/nat44.nft
    forbidden:
      systemctl restart routerd.service
      systemctl restart nftables.service

[vrrp-track-script-artifacts]
proves: VRRP track scripts remain explicit artifacts with executable permissions for keepalived callbacks.
commands:
  artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
  systemctl reload keepalived.service
forbidden:
  systemctl restart keepalived.service
os-matrix:
  systemd:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    systemctl reload keepalived.service
    forbidden:
      systemctl restart keepalived.service
  rc.d:
    artifact-write /usr/local/libexec/routerd/keepalived-track.d mode=0755
    service keepalived reload
    forbidden:
      service keepalived restart

[dslite-tunnel-event-hook]
proves: DS-Lite tunnel apply remains a dataplane hook with ipip6 tunnel updates and route event publication, not a service restart.
commands:
  modprobe ip6_tunnel
  ip -6 tunnel replace ds-lite mode ipip6
  bus publish routerd.tunnel.ds-lite.up
os-matrix:
  systemd:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up
  rc.d:
    modprobe ip6_tunnel
    ip -6 tunnel replace ds-lite mode ipip6
    bus publish routerd.tunnel.ds-lite.up

[dhcp-event-daemon-ipc-order]
proves: DHCP event relay and fingerprint watcher keep Unix-socket IPC and daemon status warmup ordering before controller bootstrap.
commands:
  daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
  daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
  bus publish routerd.controller.bootstrap
os-matrix:
  systemd:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap
  rc.d:
    daemon-status GET unix:///run/routerd/dhcpv4-client/wan.sock /v1/status
    daemon-status GET unix:///run/routerd/dhcpv6-client/wan-pd.sock /v1/status
    bus publish routerd.controller.bootstrap
