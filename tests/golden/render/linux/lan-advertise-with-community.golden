### frr-daemons
# Generated by routerd. Preserve local daemon options outside managed keys.
bgpd=yes
### frr.conf
! Generated by routerd. Do not edit by hand.
frr defaults traditional
hostname routerd
service integrated-vtysh-config
!
ip prefix-list ROUTERD-LAN-IMPORT seq 10 permit 10.240.70.200/29
ip prefix-list ROUTERD-LAN-IMPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 192.168.50.0/24
ip prefix-list ROUTERD-LAN-EXPORT seq 20 permit 198.51.100.0/24
ip prefix-list ROUTERD-LAN-EXPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-LAN-REDIST-CONNECTED seq 10 permit 192.168.50.0/24
ip prefix-list ROUTERD-LAN-REDIST-CONNECTED seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-REDIST-CONNECTED permit 10
 match ip address prefix-list ROUTERD-LAN-REDIST-CONNECTED
route-map ROUTERD-LAN-REDIST-CONNECTED deny 999
ip prefix-list ROUTERD-LAN-REDIST-STATIC seq 10 permit 198.51.100.0/24
ip prefix-list ROUTERD-LAN-REDIST-STATIC seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-REDIST-STATIC permit 10
 match ip address prefix-list ROUTERD-LAN-REDIST-STATIC
route-map ROUTERD-LAN-REDIST-STATIC deny 999
bgp community-list standard ROUTERD-LAN-COMM-ACCEPT permit 64513:100
bgp community-list standard ROUTERD-LAN-COMM-ACCEPT permit no-export
route-map ROUTERD-LAN-IN permit 10
 match ip address prefix-list ROUTERD-LAN-IMPORT
 match community ROUTERD-LAN-COMM-ACCEPT
 set ip next-hop peer-address
 set community 64512:10 additive
route-map ROUTERD-LAN-IN deny 999
route-map ROUTERD-LAN-OUT permit 10
 match ip address prefix-list ROUTERD-LAN-EXPORT
 set community 64512:20 additive
route-map ROUTERD-LAN-OUT deny 999
!
router bgp 64512
 bgp router-id 192.168.50.1
 bgp graceful-restart
 neighbor 192.168.50.21 remote-as 64513
 neighbor 192.168.50.21 send-community both
 neighbor 192.168.50.21 route-map ROUTERD-LAN-IN in
 neighbor 192.168.50.21 route-map ROUTERD-LAN-OUT out
 neighbor 192.168.50.22 remote-as 64513
 neighbor 192.168.50.22 send-community both
 neighbor 192.168.50.22 route-map ROUTERD-LAN-IN in
 neighbor 192.168.50.22 route-map ROUTERD-LAN-OUT out
 address-family ipv4 unicast
  redistribute connected route-map ROUTERD-LAN-REDIST-CONNECTED
  redistribute static route-map ROUTERD-LAN-REDIST-STATIC
  neighbor 192.168.50.21 activate
  neighbor 192.168.50.22 activate
 exit-address-family
!
