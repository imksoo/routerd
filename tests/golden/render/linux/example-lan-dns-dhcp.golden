### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19

interface=ens19
dhcp-range=set:lan-dhcpv4,192.168.30.100,192.168.30.199,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.30.1
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.30.1
dhcp-option=tag:lan-dhcpv4,option:domain-name,home.example
dhcp-option=tag:lan-dhcpv4,option:domain-search,home.example
dhcp-host=02:00:00:00:30:10,set:nas,nas,192.168.30.10
### netplan/99-routerd.yaml
# Generated by routerd. Do not edit by hand.
network:
  version: 2
  renderer: networkd
  ethernets:
    ens19:
      optional: true
      dhcp4: false
      dhcp6: false
      accept-ra: false
      link-local: []
      addresses:
        - 192.168.30.1/24
