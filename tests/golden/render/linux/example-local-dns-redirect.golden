### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19

interface=ens19
dhcp-range=set:lan-dhcpv4,192.168.50.100,192.168.50.199,12h
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.50.1
dhcp-option=tag:lan-dhcpv4,option:domain-name,home.example
dhcp-option=tag:lan-dhcpv4,option:domain-search,home.example
### firewall-holes.txt
lan-dhcpv4-dhcpv4-server-lan from=lan to=self ifnames=ens19 proto=udp port=67 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Server/lan-dhcpv4
lan-local-services-public-dns-tcp from=lan to=self ifnames=ens19 proto=tcp port=53 action=accept direction= comment=firewall.routerd.net/v1alpha1/LocalServiceRedirect/lan-local-services
lan-local-services-public-dns-udp from=lan to=self ifnames=ens19 proto=udp port=53 action=accept direction= comment=firewall.routerd.net/v1alpha1/LocalServiceRedirect/lan-local-services
### netplan/99-routerd.yaml
# Generated by routerd. Do not edit by hand.
network:
  version: 2
  renderer: networkd
  ethernets:
    ens19:
      optional: true
      dhcp4: false
      dhcp6: false
      accept-ra: false
      link-local: []
      addresses:
        - 192.168.50.1/24
### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
table inet routerd_filter {
  set if_lan { type ifname; elements = { "ens19" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    counter log prefix "routerd firewall input deny " drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    counter log prefix "routerd firewall forward deny " drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
}
### nftables-nat.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
table inet routerd_filter {
  set if_lan { type ifname; elements = { "ens19" } }
  chain input {
