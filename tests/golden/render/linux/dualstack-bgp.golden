### frr-daemons
# Generated by routerd. Preserve local daemon options outside managed keys.
bgpd=yes
### frr.conf
! Generated by routerd. Do not edit by hand.
frr defaults traditional
hostname routerd
service integrated-vtysh-config
!
ip prefix-list ROUTERD-LAN-IMPORT seq 10 permit 10.244.0.0/16
ip prefix-list ROUTERD-LAN-IMPORT seq 999 deny 0.0.0.0/0 le 32
ipv6 prefix-list ROUTERD-LAN-IMPORT-V6 seq 10 permit fd00:244::/48
ipv6 prefix-list ROUTERD-LAN-IMPORT-V6 seq 999 deny ::/0 le 128
ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.96.0.0/12
ip prefix-list ROUTERD-LAN-EXPORT seq 20 permit 192.168.70.0/24
ip prefix-list ROUTERD-LAN-EXPORT seq 999 deny 0.0.0.0/0 le 32
ipv6 prefix-list ROUTERD-LAN-EXPORT-V6 seq 10 permit fd00:70::/64
ipv6 prefix-list ROUTERD-LAN-EXPORT-V6 seq 20 permit fd00:96::/108
ipv6 prefix-list ROUTERD-LAN-EXPORT-V6 seq 999 deny ::/0 le 128
ip prefix-list ROUTERD-LAN-REDIST-CONNECTED seq 10 permit 192.168.70.0/24
ip prefix-list ROUTERD-LAN-REDIST-CONNECTED seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-REDIST-CONNECTED permit 10
 match ip address prefix-list ROUTERD-LAN-REDIST-CONNECTED
route-map ROUTERD-LAN-REDIST-CONNECTED deny 999
ip prefix-list ROUTERD-LAN-REDIST-STATIC seq 10 permit 10.96.0.0/12
ip prefix-list ROUTERD-LAN-REDIST-STATIC seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-REDIST-STATIC permit 10
 match ip address prefix-list ROUTERD-LAN-REDIST-STATIC
route-map ROUTERD-LAN-REDIST-STATIC deny 999
ipv6 prefix-list ROUTERD-LAN-REDIST-CONNECTED-V6 seq 10 permit fd00:70::/64
ipv6 prefix-list ROUTERD-LAN-REDIST-CONNECTED-V6 seq 999 deny ::/0 le 128
route-map ROUTERD-LAN-REDIST-CONNECTED-V6 permit 10
 match ipv6 address prefix-list ROUTERD-LAN-REDIST-CONNECTED-V6
route-map ROUTERD-LAN-REDIST-CONNECTED-V6 deny 999
ipv6 prefix-list ROUTERD-LAN-REDIST-STATIC-V6 seq 10 permit fd00:96::/108
ipv6 prefix-list ROUTERD-LAN-REDIST-STATIC-V6 seq 999 deny ::/0 le 128
route-map ROUTERD-LAN-REDIST-STATIC-V6 permit 10
 match ipv6 address prefix-list ROUTERD-LAN-REDIST-STATIC-V6
route-map ROUTERD-LAN-REDIST-STATIC-V6 deny 999
route-map ROUTERD-LAN-IN permit 10
 match ip address prefix-list ROUTERD-LAN-IMPORT
 set ip next-hop peer-address
route-map ROUTERD-LAN-IN deny 999
route-map ROUTERD-LAN-OUT permit 10
 match ip address prefix-list ROUTERD-LAN-EXPORT
route-map ROUTERD-LAN-OUT deny 999
route-map ROUTERD-LAN-IN-V6 permit 10
 match ipv6 address prefix-list ROUTERD-LAN-IMPORT-V6
route-map ROUTERD-LAN-IN-V6 deny 999
route-map ROUTERD-LAN-OUT-V6 permit 10
 match ipv6 address prefix-list ROUTERD-LAN-EXPORT-V6
route-map ROUTERD-LAN-OUT-V6 deny 999
!
router bgp 64512
 bgp router-id 10.0.0.1
 bgp graceful-restart
 bgp graceful-restart restart-time 120
 bgp graceful-restart stalepath-time 360
 neighbor 192.168.70.21 remote-as 64513
 neighbor 192.168.70.21 timers 3 9
 neighbor 192.168.70.21 timers connect 5
 neighbor 192.168.70.21 route-map ROUTERD-LAN-IN in
 neighbor 192.168.70.21 route-map ROUTERD-LAN-OUT out
 neighbor 192.168.70.22 remote-as 64513
 neighbor 192.168.70.22 timers 3 9
 neighbor 192.168.70.22 timers connect 5
 neighbor 192.168.70.22 route-map ROUTERD-LAN-IN in
 neighbor 192.168.70.22 route-map ROUTERD-LAN-OUT out
 neighbor fd00:70::21 remote-as 64513
 neighbor fd00:70::21 timers 3 9
 neighbor fd00:70::21 timers connect 5
 neighbor fd00:70::22 remote-as 64513
 neighbor fd00:70::22 timers 3 9
 neighbor fd00:70::22 timers connect 5
 address-family ipv4 unicast
  redistribute connected route-map ROUTERD-LAN-REDIST-CONNECTED
  redistribute static route-map ROUTERD-LAN-REDIST-STATIC
  neighbor 192.168.70.21 activate
  neighbor 192.168.70.22 activate
 exit-address-family
 address-family ipv6 unicast
  redistribute connected route-map ROUTERD-LAN-REDIST-CONNECTED-V6
  redistribute static route-map ROUTERD-LAN-REDIST-STATIC-V6
  neighbor fd00:70::21 activate
  neighbor fd00:70::21 route-map ROUTERD-LAN-IN-V6 in
  neighbor fd00:70::21 route-map ROUTERD-LAN-OUT-V6 out
  neighbor fd00:70::22 activate
  neighbor fd00:70::22 route-map ROUTERD-LAN-IN-V6 in
  neighbor fd00:70::22 route-map ROUTERD-LAN-OUT-V6 out
 exit-address-family
!
