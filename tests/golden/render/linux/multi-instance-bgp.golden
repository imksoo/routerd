### frr-daemons
# Generated by routerd. Preserve local daemon options outside managed keys.
bgpd=yes
### frr.conf
! Generated by routerd. Do not edit by hand.
frr defaults traditional
hostname routerd
service integrated-vtysh-config
!
ip prefix-list ROUTERD-LAN-IMPORT seq 10 permit 10.240.70.200/29
ip prefix-list ROUTERD-LAN-IMPORT seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-IN permit 10
 match ip address prefix-list ROUTERD-LAN-IMPORT
 set ip next-hop peer-address
route-map ROUTERD-LAN-IN deny 999
route-map ROUTERD-LAN-OUT deny 999
!
router bgp 64512
 bgp router-id 192.168.50.1
 bgp graceful-restart
 neighbor 192.168.50.21 remote-as 64513
 neighbor 192.168.50.21 route-map ROUTERD-LAN-IN in
 neighbor 192.168.50.21 route-map ROUTERD-LAN-OUT out
 neighbor 192.168.50.22 remote-as 64513
 neighbor 192.168.50.22 route-map ROUTERD-LAN-IN in
 neighbor 192.168.50.22 route-map ROUTERD-LAN-OUT out
 address-family ipv4 unicast
  neighbor 192.168.50.21 activate
  neighbor 192.168.50.22 activate
 exit-address-family
!
ip prefix-list ROUTERD-WAN-PEERING-IMPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-WAN-PEERING-EXPORT seq 10 permit 198.51.100.0/24
ip prefix-list ROUTERD-WAN-PEERING-EXPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-WAN-PEERING-REDIST-STATIC seq 10 permit 198.51.100.0/24
ip prefix-list ROUTERD-WAN-PEERING-REDIST-STATIC seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-WAN-PEERING-REDIST-STATIC permit 10
 match ip address prefix-list ROUTERD-WAN-PEERING-REDIST-STATIC
route-map ROUTERD-WAN-PEERING-REDIST-STATIC deny 999
route-map ROUTERD-WAN-PEERING-IN permit 10
 match ip address prefix-list ROUTERD-WAN-PEERING-IMPORT
 set ip next-hop peer-address
route-map ROUTERD-WAN-PEERING-IN deny 999
route-map ROUTERD-WAN-PEERING-OUT permit 10
 match ip address prefix-list ROUTERD-WAN-PEERING-EXPORT
route-map ROUTERD-WAN-PEERING-OUT deny 999
!
router bgp 65001 vrf vrf-wan
 bgp router-id 192.0.2.2
 bgp graceful-restart
 neighbor 192.0.2.254 remote-as 65002
 neighbor 192.0.2.254 route-map ROUTERD-WAN-PEERING-IN in
 neighbor 192.0.2.254 route-map ROUTERD-WAN-PEERING-OUT out
 address-family ipv4 unicast
  redistribute static route-map ROUTERD-WAN-PEERING-REDIST-STATIC
  neighbor 192.0.2.254 activate
 exit-address-family
!
