### frr-daemons
# Generated by routerd. Preserve local daemon options outside managed keys.
bgpd=yes
### frr.conf
! Generated by routerd. Do not edit by hand.
frr defaults traditional
hostname routerd
service integrated-vtysh-config
!
ip prefix-list ROUTERD-LAN-IMPORT seq 10 permit 10.250.0.0/24
ip prefix-list ROUTERD-LAN-IMPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-LAN-EXPORT seq 10 permit 10.250.0.0/24
ip prefix-list ROUTERD-LAN-EXPORT seq 999 deny 0.0.0.0/0 le 32
ip prefix-list ROUTERD-LAN-UPSTREAM-192-168-1-1-EXPORT seq 10 permit 10.250.0.0/24
ip prefix-list ROUTERD-LAN-UPSTREAM-192-168-1-1-EXPORT seq 999 deny 0.0.0.0/0 le 32
route-map ROUTERD-LAN-IN permit 10
 match ip address prefix-list ROUTERD-LAN-IMPORT
 set ip next-hop peer-address
route-map ROUTERD-LAN-IN deny 999
route-map ROUTERD-LAN-OUT permit 10
 match ip address prefix-list ROUTERD-LAN-EXPORT
route-map ROUTERD-LAN-OUT deny 999
route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-IN permit 10
 match ip address prefix-list ROUTERD-LAN-IMPORT
 set ip next-hop peer-address
route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-IN deny 999
route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-OUT permit 10
 match ip address prefix-list ROUTERD-LAN-UPSTREAM-192-168-1-1-EXPORT
route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-OUT deny 999
!
router bgp 64512
 bgp router-id 192.168.1.248
 bgp graceful-restart
 neighbor 192.168.1.1 remote-as 64514
 neighbor 192.168.1.1 route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-IN in
 neighbor 192.168.1.1 route-map ROUTERD-LAN-UPSTREAM-192-168-1-1-OUT out
 neighbor 192.168.1.54 remote-as 64513
 neighbor 192.168.1.54 route-map ROUTERD-LAN-IN in
 neighbor 192.168.1.54 route-map ROUTERD-LAN-OUT out
 neighbor 192.168.1.55 remote-as 64513
 neighbor 192.168.1.55 route-map ROUTERD-LAN-IN in
 neighbor 192.168.1.55 route-map ROUTERD-LAN-OUT out
 neighbor 192.168.1.56 remote-as 64513
 neighbor 192.168.1.56 route-map ROUTERD-LAN-IN in
 neighbor 192.168.1.56 route-map ROUTERD-LAN-OUT out
 address-family ipv4 unicast
  neighbor 192.168.1.1 activate
  neighbor 192.168.1.54 activate
  neighbor 192.168.1.55 activate
  neighbor 192.168.1.56 activate
 exit-address-family
!
