}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    oifname "ppp-home" ip saddr 192.168.40.0/24 ip daddr !=10.0.0.0/8 ip daddr !=172.16.0.0/12 ip daddr !=192.168.0.0/16 masquerade
  }
}
