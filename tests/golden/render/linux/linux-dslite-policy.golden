add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "ens19" oifname { "ds-routerd-test", "ens18" } ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size set 1420
    iifname "ens19" oifname { "ds-routerd-test", "ens18" } meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size set 1400
  }
}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    # net.routerd.net/v1alpha1/NAT44Rule/lan-to-wan skipped: egressInterface is resolved by ipv4-default at runtime
  }
}
