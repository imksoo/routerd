### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ds-routerd-test
except-interface=ens18
except-interface=ens20
except-interface=lo

interface=ens19
dhcp-range=set:lan-dhcpv4,192.168.160.100,192.168.160.200,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:ntp-server,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:domain-name,lab.example
dhcp-option=tag:lan-dhcpv4,option:domain-search,lab.example

interface=ens19
enable-ra
dhcp-range=set:lan-dhcpv6,::,constructor:ens19,ra-stateless,64,12h
dhcp-option=tag:lan-dhcpv6,option6:domain-search,lab.example
interface=ens19
enable-ra
ra-param=ens19,mtu:1500,high,0,7200
dhcp-option=option6:domain-search,lab.example
### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
destroy set inet routerd_filter if_management
destroy set inet routerd_filter if_wan
table inet routerd_filter {
  set if_lan { type ifname; elements = { "ens19" } }
  set if_management { type ifname; elements = { "ens20" } }
  set if_wan { type ifname; elements = { "ds-routerd-test", "ens18" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    iifname @if_management jump management_to_self
    iifname @if_wan jump wan_to_self
    counter log prefix "routerd firewall input deny " drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_management jump lan_to_management
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_management oifname @if_lan jump management_to_lan
    iifname @if_management oifname @if_management jump management_to_management
    iifname @if_management oifname @if_wan jump management_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_management jump wan_to_management
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter log prefix "routerd firewall forward deny " drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_management {
    counter log prefix "routerd firewall lan-to-management deny " drop
  }
  chain lan_to_wan {
    counter accept
  }
  chain management_to_self {
    counter accept
  }
  chain management_to_lan {
    counter accept
  }
  chain management_to_management {
    counter accept
  }
  chain management_to_wan {
    counter accept
  }
  chain wan_to_self {
    iifname "ens18" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6Information/wan-info"
    iifname "ens18" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd"
    counter log prefix "routerd firewall wan-to-self deny " drop
  }
  chain wan_to_lan {
    counter log prefix "routerd firewall wan-to-lan deny " drop
  }
  chain wan_to_management {
    counter log prefix "routerd firewall wan-to-management deny " drop
  }
  chain wan_to_wan {
    counter accept
  }
}
