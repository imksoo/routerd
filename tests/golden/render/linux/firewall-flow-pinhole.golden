### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
destroy set inet routerd_filter if_wan
destroy set inet routerd_filter ip_address_set_camera_clients_v4
destroy set inet routerd_filter flow_pinhole_camera_cloud_udp
table inet routerd_filter {
  comment "routerd.owner=routerd routerd.generation=1"
  set if_lan { type ifname; elements = { "ens19" } }
  set if_wan { type ifname; elements = { "ens18" } }
  set ip_address_set_camera_clients_v4 { type ipv4_addr; elements = { 172.18.1.92 }; }
  set flow_pinhole_camera_cloud_udp { type ipv4_addr . inet_service; flags timeout; }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    iifname @if_wan jump wan_to_self
    counter drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_wan {
    ip saddr @ip_address_set_camera_clients_v4 ip daddr 3.114.54.243/32 udp dport 32100 update @flow_pinhole_camera_cloud_udp { ip saddr . udp sport timeout 180s } counter comment "routerd FirewallFlowPinhole camera-cloud-udp learn"
    counter accept
  }
  chain wan_to_self {
    counter drop
  }
  chain wan_to_lan {
    ip saddr 3.114.54.243/32 ip daddr @ip_address_set_camera_clients_v4 udp sport 32099 ip daddr . udp dport @flow_pinhole_camera_cloud_udp counter accept comment "routerd FirewallFlowPinhole camera-cloud-udp allow"
    counter drop
  }
  chain wan_to_wan {
    counter accept
  }
}
