### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19

interface=ens19
dhcp-range=set:lan-dhcpv4,192.168.30.100,192.168.30.199,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.30.254
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.30.254

interface=ens19
enable-ra
dhcp-range=set:lan-dhcpv6,fd00:30::100,fd00:30::1ff,constructor:ens19,64,12h
### keepalived.conf
# Generated by routerd. Do not edit by hand.
global_defs {
  router_id routerd
}

vrrp_instance lan_vip {
  state BACKUP
  interface ens19
  virtual_router_id 30
  priority 150
  advert_int 1
  nopreempt
  unicast_peer {
    192.168.30.3
  }
  virtual_ipaddress {
    192.168.30.254/32 dev ens19
  }
}

