### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ens18
except-interface=ens20

dhcp-authoritative
dhcp-range=set:lan-dhcpv4,192.168.10.100,192.168.10.199,255.255.255.0,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.10.3
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.10.3
dhcp-host=02:00:00:00:01:50,192.168.10.150,printer,infinite
### firewall-holes.txt
lan-dhcpv4-dhcpv4-server-lan from=lan to=self ifnames=ens19 proto=udp port=67 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Server/lan-dhcpv4
lan-dhcpv6-dhcpv6-server-lan from=lan to=self ifnames=ens19 proto=udp port=547 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv6Server/lan-dhcpv6
mgmt-dhcpv4-dhcpv4-client from=mgmt to=self ifnames=ens20 proto=udp port=68 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Client/mgmt-dhcpv4
transix-dslite-ipip from=self to=wan ifnames=ens18 proto=ipip port=0 action=accept direction= comment=net.routerd.net/v1alpha1/DSLiteTunnel/transix
wan-dhcpv4-dhcpv4-client from=wan to=self ifnames=ens18 proto=udp port=68 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4
wan-pd-dhcpv6-client from=wan to=self ifnames=ens18 proto=udp port=546 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd
### netplan/99-routerd.yaml
# Generated by routerd. Do not edit by hand.
network:
  version: 2
  renderer: networkd
  ethernets:
    ens19:
      optional: true
      dhcp4: false
      dhcp6: false
      accept-ra: false
      link-local:
        - ipv6
      addresses:
        - 192.168.10.3/24
    ens20:
      optional: true
      dhcp4: false
      dhcp6: false
      accept-ra: false
      link-local: []
### networkd/etc/systemd/network/10-netplan-ens18.network.d/91-routerd-ntp.conf
[Network]
NTP=pool.ntp.org
