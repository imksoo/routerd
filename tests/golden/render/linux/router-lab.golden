### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
destroy set inet routerd_filter if_mgmt
destroy set inet routerd_filter if_wan
table inet routerd_filter {
  set if_lan { type ifname; elements = { "ens19" } }
  set if_mgmt { type ifname; elements = { "ens20" } }
  set if_wan { type ifname; elements = { "ds-transix", "ens18" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    iifname @if_mgmt jump mgmt_to_self
    iifname @if_wan jump wan_to_self
    counter log prefix "routerd firewall input deny " drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_mgmt jump lan_to_mgmt
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_mgmt oifname @if_lan jump mgmt_to_lan
    iifname @if_mgmt oifname @if_mgmt jump mgmt_to_mgmt
    iifname @if_mgmt oifname @if_wan jump mgmt_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_mgmt jump wan_to_mgmt
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter log prefix "routerd firewall forward deny " drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_mgmt {
    counter log prefix "routerd firewall lan-to-mgmt deny " drop
  }
  chain lan_to_wan {
    counter accept
  }
  chain mgmt_to_self {
    counter accept
  }
  chain mgmt_to_lan {
    counter accept
  }
  chain mgmt_to_mgmt {
    counter accept
  }
  chain mgmt_to_wan {
    counter accept
  }
  chain wan_to_self {
    iifname "ens18" udp dport 68 counter accept comment "net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4"
    iifname "ens18" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd"
    counter log prefix "routerd firewall wan-to-self deny " drop
  }
  chain wan_to_lan {
    counter log prefix "routerd firewall wan-to-lan deny " drop
  }
  chain wan_to_mgmt {
    counter log prefix "routerd firewall wan-to-mgmt deny " drop
  }
  chain wan_to_wan {
    counter accept
  }
}
