add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "ens19" oifname { "ds-transix", "ens18" } ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size set 1414
    iifname "ens19" oifname { "ds-transix", "ens18" } meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size set 1394
  }
}
add table ip routerd_policy
flush table ip routerd_policy
table ip routerd_policy {
  chain prerouting {
    type filter hook prerouting priority mangle; policy accept;
    ip saddr 192.168.10.0/24 meta mark set 0x100
  }
}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    oifname "ds-transix" ip saddr 192.168.10.0/24 meta l4proto { tcp, udp } masquerade to :1024-65535
    oifname "ds-transix" ip saddr 192.168.10.0/24 masquerade
  }
}
