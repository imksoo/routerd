### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ds-transix
except-interface=ens18

dhcp-range=set:lan-dhcpv4,192.168.10.100,192.168.10.199,255.255.255.0,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.10.3
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.10.3
### firewall-holes.txt
lan-dhcpv4-dhcpv4-server-lan from=lan to=self ifnames=ens19 proto=udp port=67 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Server/lan-dhcpv4
lan-resolver-dns-tcp-lan from=lan to=self ifnames= proto=tcp port=53 action=accept direction= comment=net.routerd.net/v1alpha1/DNSResolver/lan-resolver
lan-resolver-dns-udp-lan from=lan to=self ifnames= proto=udp port=53 action=accept direction= comment=net.routerd.net/v1alpha1/DNSResolver/lan-resolver
wan-dhcpv4-dhcpv4-client from=wan to=self ifnames=ens18 proto=udp port=68 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4
wan-pd-dhcpv6-client from=wan to=self ifnames=ens18 proto=udp port=546 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd
### netplan/99-routerd.yaml
# Generated by routerd. Do not edit by hand.
network:
  version: 2
  renderer: networkd
  ethernets:
    ens19:
      optional: true
      dhcp4: false
      dhcp6: false
      accept-ra: false
      link-local:
        - ipv6
      addresses:
        - 192.168.10.3/24
### networkd/etc/systemd/network/10-netplan-ens18.network.d/91-routerd-ntp.conf
[Network]
NTP=pool.ntp.org
### networkd/etc/systemd/network/10-netplan-ens18.network.d/92-routerd-static-routes.conf
# Generated by routerd. Do not edit by hand.

[Route]
Destination=192.0.2.0/24
Gateway=192.168.1.1
### networkd/etc/systemd/network/10-netplan-ens19.network.d/92-routerd-static-routes.conf
# Generated by routerd. Do not edit by hand.

[Route]
Destination=2001:db8:10::/64
Gateway=fe80::1
GatewayOnLink=yes
### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
destroy set inet routerd_filter if_wan
table inet routerd_filter {
  comment "routerd.owner=routerd routerd.generation=1"
  set if_lan { type ifname; elements = { "ens19" } }
  set if_wan { type ifname; elements = { "ds-transix", "ens18" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    iifname @if_wan jump wan_to_self
    counter log prefix "routerd firewall input deny " drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter log prefix "routerd firewall forward deny " drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_wan {
    counter accept
  }
  chain wan_to_self {
    iifname "ens18" udp dport 68 counter accept comment "net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4"
    iifname "ens18" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd"
    counter log prefix "routerd firewall wan-to-self deny " drop
  }
  chain wan_to_lan {
    counter log prefix "routerd firewall wan-to-lan deny " drop
  }
  chain wan_to_wan {
    counter accept
  }
}
