### pf.conf
# Generated by routerd. Do not edit by hand.
set skip on lo0
rdr pass on eth0 inet proto tcp from any to 192.0.2.10 port 6443 -> 192.0.2.11 port 6443
pass all keep state
### rc.conf.d-routerd
# Generated by routerd. Do not edit by hand.
gateway_enable="YES"
ipv6_gateway_enable="YES"
pf_enable="YES"
pflog_enable="YES"
