    if ! ${name}_supervisor_pid >/dev/null 2>&1 && ! ${name}_managed_child_pid >/dev/null 2>&1; then
      rm -f "${daemon_pidfile}" "${child_pidfile}"
      return 0
    fi
    sleep 1
  done
  warn "${name} did not stop after TERM; sending KILL"
  _supervisor_pid=$(${name}_supervisor_pid)
  _child_pid=$(${name}_child_pid)
  if [ -n "${_supervisor_pid}" ]; then kill -KILL "${_supervisor_pid}" 2>/dev/null || true; fi
  if [ -n "${_child_pid}" ]; then kill -KILL "${_child_pid}" 2>/dev/null || true; fi
  for _try in 1 2 3 4 5; do
    if ! ${name}_supervisor_pid >/dev/null 2>&1 && ! ${name}_managed_child_pid >/dev/null 2>&1; then
      rm -f "${daemon_pidfile}" "${child_pidfile}"
      return 0
    fi
    sleep 1
  done
  warn "failed to stop ${name}"
  return 1
}

routerd_dhcpv6_client_wan_pd_status() {
  _child_pid=$(${name}_child_pid)
  if [ -z "${_child_pid}" ]; then
    echo "${name} is not running."
    return 1
  fi
  echo "${name} is running as pid ${_child_pid}."
}

load_rc_config $name
: ${routerd_dhcpv6_client_wan_pd_enable:="YES"}
run_rc_command "$1"
