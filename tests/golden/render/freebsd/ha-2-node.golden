### rc.conf.d-routerd
# Generated by routerd. Do not edit by hand.
gateway_enable="YES"
ipv6_gateway_enable="YES"
routerd_carp_enable="YES"
### rc.d-routerd_carp
#!/bin/sh
#
# Managed by routerd.
#
# PROVIDE: routerd_carp
# REQUIRE: NETWORKING
# KEYWORD: shutdown

. /etc/rc.subr

name="routerd_carp"
rcvar="routerd_carp_enable"
start_cmd="routerd_carp_start"
stop_cmd="routerd_carp_stop"
status_cmd="routerd_carp_status"

routerd_carp_start() {
  kldload carp >/dev/null 2>&1 || true
  sysctl net.inet.carp.preempt='0' >/dev/null
  ifconfig 'ens20' 'inet' 'vhid' '70' 'advbase' '1' 'advskew' '104' 'alias' '192.168.70.10/32'
}

routerd_carp_stop() {
  ifconfig 'ens20' inet '192.168.70.10/32' -alias >/dev/null 2>&1 || true
}

routerd_carp_status() {
  true && ifconfig 'ens20' | grep -q 'vhid 70'
}

load_rc_config $name
: ${routerd_carp_enable:="YES"}
run_rc_command "$1"
