### pf.conf
# Generated by routerd. Do not edit by hand.
set skip on lo0
lan_if = "ens19"
wan_if = "ens18"
block drop all
pass quick on lo0 all
pass out quick all keep state
pass quick inet6 proto icmp6 all keep state
pass in quick on $lan_if to self keep state
block return in quick on $wan_if proto tcp to self port 22 keep state label "routerd:ssh-bruteforce-over-limit"
pass in quick on $wan_if inet proto icmp icmp-type echoreq to self keep state label "routerd:wan-icmp-echo"
pass in quick on $wan_if proto tcp to self port { 80 443 } keep state label "routerd:wan-web"
pass in quick on $lan_if keep state label "routerd:lan-to-lan"
pass in quick on $lan_if keep state label "routerd:lan-to-wan"
### rc.conf.d-routerd
# Generated by routerd. Do not edit by hand.
gateway_enable="YES"
ipv6_gateway_enable="YES"
pf_enable="YES"
pflog_enable="YES"
