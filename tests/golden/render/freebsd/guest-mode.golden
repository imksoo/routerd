### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/db/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ens18

interface=ens19
dhcp-range=set:lan-v4,172.18.1.64,172.18.1.191,12h
dhcp-option=tag:lan-v4,option:router,172.18.0.1
dhcp-option=tag:lan-v4,option:dns-server,172.18.0.1
dhcp-option=tag:lan-v4,option:ntp-server,172.18.0.1
dhcp-option=tag:lan-v4,option:domain-name,home.internal
dhcp-option=tag:lan-v4,option:domain-search,home.internal
dhcp-host=18:ec:e7:33:12:6c,set:aiseg2,aiseg2,172.18.0.150
### firewall-holes.txt
lan-v4-dhcpv4-server-lan from=lan to=self ifnames=ens19 proto=udp port=67 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Server/lan-v4
### pf.conf
# Generated by routerd. Do not edit by hand.
set skip on lo0
lan_if = "ens19"
wan_if = "ens18"
block drop all
pass quick on lo0 all
pass out quick all keep state
pass quick inet6 proto icmp6 all keep state
pass in quick on $lan_if to self keep state
pass in quick on $lan_if keep state label "routerd:lan-to-lan"
pass in quick on $lan_if keep state label "routerd:lan-to-wan"
### rc.conf.d-routerd
# Generated by routerd. Do not edit by hand.
gateway_enable="YES"
ipv6_gateway_enable="YES"
pf_enable="YES"
pflog_enable="YES"
### rc.d-routerd_dnsmasq
#!/bin/sh

# PROVIDE: routerd_dnsmasq
# REQUIRE: NETWORKING mpd5
# KEYWORD: shutdown

. /etc/rc.subr

name="routerd_dnsmasq"
rcvar="routerd_dnsmasq_enable"
command="/usr/local/sbin/dnsmasq"
pidfile="/var/run/routerd/dnsmasq.pid"
command_args="--conf-file=/usr/local/etc/routerd/dnsmasq.conf --pid-file=${pidfile}"
start_precmd="${name}_prestart"

routerd_dnsmasq_prestart()
{
	mkdir -p "/var/run/routerd"
	mkdir -p "/var/db/routerd/dnsmasq"
}

load_rc_config ${name}
: ${routerd_dnsmasq_enable:="NO"}

run_rc_command "$1"
