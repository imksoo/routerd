add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  comment "routerd.owner=routerd routerd.generation=1"
  set ip_address_set_public_dns { type ipv4_addr; }
  chain prerouting {
    type nat hook prerouting priority dstnat; policy accept;
    iifname "ens19" ip daddr @ip_address_set_public_dns tcp dport 53 counter redirect to :53 comment "routerd LocalServiceRedirect lan-local-services public-dns"
    iifname "ens19" ip daddr @ip_address_set_public_dns udp dport 53 counter redirect to :53 comment "routerd LocalServiceRedirect lan-local-services public-dns"
  }
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
  }
}
add table ip6 routerd_nat
flush table ip6 routerd_nat
table ip6 routerd_nat {
  comment "routerd.owner=routerd routerd.generation=1"
  set ip_address_set_public_dns { type ipv6_addr; }
  chain prerouting {
    type nat hook prerouting priority dstnat; policy accept;
    iifname "ens19" ip6 daddr @ip_address_set_public_dns tcp dport 53 counter redirect to :53 comment "routerd LocalServiceRedirect lan-local-services public-dns"
    iifname "ens19" ip6 daddr @ip_address_set_public_dns udp dport 53 counter redirect to :53 comment "routerd LocalServiceRedirect lan-local-services public-dns"
  }
}
### openrc-routerd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd'
description='routerd daemon'
command='/usr/local/sbin/routerd'
command_args="'serve'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/run/routerd/bgp'
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/run/routerd/dns-resolver'
	checkpath -d -m 0755 '/run/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/lib/routerd'
	checkpath -d -m 0755 '/var/log/routerd'
	'/usr/local/sbin/routerd' 'check'
}
### openrc-routerd_dns_resolver_lan_resolver
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dns_resolver_lan_resolver'
description='routerd DNS resolver lan-resolver'
command='/usr/local/sbin/routerd-dns-resolver'
command_args="'daemon' '--resource' 'lan-resolver' '--config-file' '/var/lib/routerd/dns-resolver/lan-resolver/config.json'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dns-resolver'
	checkpath -d -m 0755 '/var/lib/routerd/dns-resolver'
	checkpath -d -m 0755 '/var/lib/routerd/dns-resolver/lan-resolver'
	checkpath -d -m 0755 '/var/log/routerd'
}
### openrc-routerd_dnsmasq
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dnsmasq'
description='routerd managed dnsmasq DHCP service'
command='/usr/sbin/dnsmasq'
command_args="'--keep-in-foreground' '--user=root' '--group=root' '--conf-file=/usr/local/etc/routerd/dnsmasq.conf' '--pid-file=/run/routerd/dnsmasq.pid'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
