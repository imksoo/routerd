    iifname "ens19" ether saddr @client_policy_guest_devices ip daddr 224.0.0.251 udp dport 5353 counter log prefix "routerd client-policy guest-devices discovery deny " drop
    iifname "ens19" ether saddr @client_policy_guest_devices ip6 daddr ff02::fb udp dport 5353 counter log prefix "routerd client-policy guest-devices discovery deny " drop
    iifname "ens19" ether saddr @client_policy_guest_devices ip daddr 239.255.255.250 udp dport 1900 counter log prefix "routerd client-policy guest-devices discovery deny " drop
    iifname "ens19" ether saddr @client_policy_guest_devices ip6 daddr ff02::c udp dport 1900 counter log prefix "routerd client-policy guest-devices discovery deny " drop
