### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ens18

interface=ens19
dhcp-range=set:lan-v4,172.18.1.64,172.18.1.191,12h
dhcp-option=tag:lan-v4,option:router,172.18.0.1
dhcp-option=tag:lan-v4,option:dns-server,172.18.0.1
dhcp-option=tag:lan-v4,option:ntp-server,172.18.0.1
dhcp-option=tag:lan-v4,option:domain-name,home.internal
dhcp-option=tag:lan-v4,option:domain-search,home.internal
dhcp-host=18:ec:e7:33:12:6c,set:aiseg2,aiseg2,172.18.0.150
### openrc-routerd_dnsmasq
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dnsmasq'
description='routerd managed dnsmasq DHCP service'
command='/usr/sbin/dnsmasq'
command_args="'--keep-in-foreground' '--user=root' '--group=root' '--conf-file=/usr/local/etc/routerd/dnsmasq.conf' '--pid-file=/run/routerd/dnsmasq.pid'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
