    iifname "ens19" ether saddr @client_policy_guest_devices tcp dport 53 counter accept comment "routerd client policy guest-devices guest DNS"
    iifname "ens19" ether saddr @client_policy_guest_devices udp dport { 67, 547 } counter accept comment "routerd client policy guest-devices guest DHCP"
