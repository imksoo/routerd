### openrc-routerd_pppoe_client_pppoe_flets
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_pppoe_client_pppoe_flets'
description='routerd PPPoE client pppoe-flets'
command='/usr/local/sbin/routerd-pppoe-client'
command_args="'daemon' '--resource' 'pppoe-flets' '--interface' 'ens18' '--username' 'open@open.ad.jp' '--password-file' '/usr/local/etc/routerd/secrets/pppoe-flets.password' '--mtu' '1454' '--mru' '1454'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/lib/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/log/routerd'
}
