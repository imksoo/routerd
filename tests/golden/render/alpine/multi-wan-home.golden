add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  comment "routerd.owner=routerd routerd.generation=1"
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "ens19" oifname { "ds-lite-a", "ds-lite-b" } ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size > 1414 tcp option maxseg size set 1414
    iifname "ens19" oifname { "ds-lite-a", "ds-lite-b" } meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size > 1394 tcp option maxseg size set 1394
    iifname "ens19" oifname "ens18" ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size > 1460 tcp option maxseg size set 1460
    iifname "ens19" oifname "ens18" meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size > 1440 tcp option maxseg size set 1440
  }
}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  comment "routerd.owner=routerd routerd.generation=1"
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    # net.routerd.net/v1alpha1/NAT44Rule/lan-to-selected-wan skipped: egressInterface is resolved by ipv4-default at runtime
  }
}
### openrc-routerd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd'
description='routerd daemon'
command='/usr/local/sbin/routerd'
command_args="'serve' '--config' '/usr/local/etc/routerd/router.yaml' '--socket' '/run/routerd/routerd.sock' '--status-socket' '/run/routerd/routerd-status.sock' '--apply-interval' '60s'"
command_background="yes"
pidfile="/run/routerd/routerd.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/run/routerd/bgp'
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/run/routerd/dns-resolver'
	checkpath -d -m 0755 '/run/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/lib/routerd'
	checkpath -d -m 0755 '/var/log/routerd'
}
### openrc-routerd_healthcheck_internet_a
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_healthcheck_internet_a'
description='routerd healthcheck internet-a'
command='/usr/local/sbin/routerd-healthcheck'
command_args="'daemon' '--resource' 'internet-a' '--target' '1.1.1.1' '--protocol' 'tcp' '--address-family' 'ipv4' '--port' '443' '--socket' '/run/routerd/healthcheck/internet-a.sock' '--state-file' '/var/lib/routerd/healthcheck/internet-a/state.json' '--event-file' '/var/log/routerd/healthcheck/internet-a/events.jsonl'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/healthcheck'
	checkpath -d -m 0755 '/var/lib/routerd/healthcheck'
	checkpath -d -m 0755 '/var/log/routerd'
}
