### nftables-nat.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  comment "routerd.owner=routerd routerd.generation=1"
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "ens19" oifname "wg-hybrid" ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size > 1300 tcp option maxseg size set 1300
  }
}
add table ip routerd_forcefrag
flush table ip routerd_forcefrag
table ip routerd_forcefrag {
  comment "routerd.owner=routerd routerd.generation=1"
  chain prerouting {
    type filter hook prerouting priority mangle; policy accept;
    iifname "ens19" fib daddr oifname "wg-hybrid" ip length > 1340 ip frag-off 0x4000 ip frag-off set 0
  }
}
### openrc-routerd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd'
description='routerd daemon'
command='/usr/local/sbin/routerd'
command_args="'serve' '--config' '/usr/local/etc/routerd/router.yaml' '--socket' '/run/routerd/routerd.sock' '--status-socket' '/run/routerd/routerd-status.sock' '--apply-interval' '60s'"
command_background="yes"
pidfile="/run/routerd/routerd.pid"

depend() {
	use net
}

start_pre() {
	routerd_stop_client_daemons
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/run/routerd/bgp'
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/run/routerd/dns-resolver'
	checkpath -d -m 0755 '/run/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/lib/routerd'
	checkpath -d -m 0755 '/var/log/routerd'
}

stop_post() {
	routerd_stop_client_daemons
}

routerd_stop_client_daemons() {
	pids=''
	for daemon in routerd-dns-resolver routerd-dhcpv4-client routerd-dhcpv6-client routerd-pppoe-client routerd-arp-observer; do
		for pid in $(pidof "${daemon}" 2>/dev/null || true); do
			cmdline=$(tr '\000' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true)
			case " ${cmdline} " in
				*' --socket /run/routerd/'*|*' --socket /var/run/routerd/'*) pids="${pids} ${pid}" ;;
			esac
		done
	done
	[ -n "${pids}" ] || return 0
	# shellcheck disable=SC2086
	kill -TERM ${pids} 2>/dev/null || true
	i=0
	while [ "${i}" -lt 20 ]; do
		alive=''
		for pid in ${pids}; do
			[ -d "/proc/${pid}" ] && alive="${alive} ${pid}"
		done
		[ -z "${alive}" ] && return 0
		sleep 0.5
		i=$((i + 1))
	done
	# shellcheck disable=SC2086
	kill -KILL ${alive} 2>/dev/null || true
}
