### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=ens19
except-interface=ds-routerd-test
except-interface=ens18
except-interface=ens20
except-interface=lo

interface=ens19
dhcp-range=set:lan-dhcpv4,192.168.160.100,192.168.160.200,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:ntp-server,192.168.160.5
dhcp-option=tag:lan-dhcpv4,option:domain-name,lab.example
dhcp-option=tag:lan-dhcpv4,option:domain-search,lab.example

interface=ens19
enable-ra
dhcp-range=set:lan-dhcpv6,::,constructor:ens19,ra-stateless,64,12h
dhcp-option=tag:lan-dhcpv6,option6:domain-search,lab.example
interface=ens19
enable-ra
ra-param=ens19,mtu:1500,high,0,7200
dhcp-option=option6:domain-search,lab.example
### openrc-routerd_dhcpv6_client_wan_pd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dhcpv6_client_wan_pd'
description='routerd DHCPv6-PD client wan-pd'
command='/usr/local/sbin/routerd-dhcpv6-client'
command_args="'daemon' '--resource' 'wan-pd' '--interface' 'ens18' '--socket' '/run/routerd/dhcpv6-client/wan-pd.sock' '--lease-file' '/var/lib/routerd/dhcpv6-client/wan-pd/lease.json' '--event-file' '/var/lib/routerd/dhcpv6-client/wan-pd/events.jsonl' '--iaid' '1'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv6-client/wan-pd'
	checkpath -d -m 0755 '/var/log/routerd'
}
