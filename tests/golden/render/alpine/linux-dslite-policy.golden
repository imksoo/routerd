### openrc-routerd_dnsmasq
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dnsmasq'
description='routerd managed dnsmasq DHCP service'
command='/usr/sbin/dnsmasq'
command_args="'--keep-in-foreground' '--user=root' '--group=root' '--conf-file=/usr/local/etc/routerd/dnsmasq.conf' '--pid-file=/run/routerd/dnsmasq.pid'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
### openrc-routerd_healthcheck_internet_icmp
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_healthcheck_internet_icmp'
description='routerd healthcheck internet-icmp'
command='/usr/local/sbin/routerd-healthcheck'
command_args="'daemon' '--resource' 'internet-icmp' '--target' '1.1.1.1' '--protocol' 'icmp' '--interval' '30s' '--timeout' '3s' '--healthy-threshold' '1' '--unhealthy-threshold' '3' '--socket' '/run/routerd/healthcheck/internet-icmp.sock' '--state-file' '/var/lib/routerd/healthcheck/internet-icmp/state.json' '--event-file' '/var/log/routerd/healthcheck/internet-icmp/events.jsonl'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/healthcheck'
	checkpath -d -m 0755 '/var/lib/routerd/healthcheck'
	checkpath -d -m 0755 '/var/log/routerd'
}
