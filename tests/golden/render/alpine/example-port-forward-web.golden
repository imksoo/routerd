  }
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    iifname "ens19" ip daddr 192.168.10.20 tcp dport 443 ct original ip daddr 203.0.113.10 ct original proto-dst 443 counter masquerade comment "routerd PortForward web-https hairpin"
  }
