table ip routerd_nat {
  comment "routerd.owner=routerd routerd.generation=1"
  chain prerouting {
    type nat hook prerouting priority dstnat; policy accept;
    iifname "ens18" ip daddr 203.0.113.10 tcp dport 443 counter dnat to 192.168.10.20:443 comment "routerd PortForward web-https"
