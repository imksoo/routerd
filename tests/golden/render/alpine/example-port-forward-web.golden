    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname "ens18" ip daddr 192.168.10.20 tcp dport 443 counter accept comment "routerd PortForward web-https"
    iifname "ens19" ip daddr 192.168.10.20 tcp dport 443 counter accept comment "routerd PortForward web-https hairpin"
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter log prefix "routerd firewall forward deny " drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_wan {
    counter accept
  }
  chain wan_to_self {
