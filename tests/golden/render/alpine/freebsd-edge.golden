    iifname "vtnet0" udp dport 68 counter accept comment "net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4"
    iifname "vtnet0" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd"
    iifname "vtnet0" udp dport 51820 counter accept comment "net.routerd.net/v1alpha1/WireGuardInterface/wg-lab"
