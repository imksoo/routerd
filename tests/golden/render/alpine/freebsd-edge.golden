### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=vtnet1
except-interface=vtnet0
except-interface=vtnet2

dhcp-authoritative
dhcp-range=set:lan-dhcpv4,192.0.2.110,192.0.2.119,255.255.255.0,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.0.2.1
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.0.2.1
dhcp-host=02:00:00:00:01:50,192.0.2.115,printer,infinite
### firewall-holes.txt
home-tailscale from=wan to=self ifnames=vtnet0 proto=udp port=41641 action=accept direction= comment=net.routerd.net/v1alpha1/TailscaleNode/home
lan-dhcpv4-server-dhcpv4-server-lan from=lan to=self ifnames=vtnet1 proto=udp port=67 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Server/lan-dhcpv4-server
lan-dhcpv6-server-dhcpv6-server-lan from=lan to=self ifnames=vtnet1 proto=udp port=547 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv6Server/lan-dhcpv6-server
mgmt-dhcpv4-dhcpv4-client from=mgmt to=self ifnames=vtnet2 proto=udp port=68 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Client/mgmt-dhcpv4
static-dslite-example-dslite-ipip from=self to=wan ifnames=vtnet0 proto=ipip port=0 action=accept direction= comment=net.routerd.net/v1alpha1/DSLiteTunnel/static-dslite-example
wan-dhcpv4-dhcpv4-client from=wan to=self ifnames=vtnet0 proto=udp port=68 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4
wan-pd-dhcpv6-client from=wan to=self ifnames=vtnet0 proto=udp port=546 action=accept direction= comment=net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd
wg-lab-wireguard from=wan to=self ifnames=vtnet0 proto=udp port=51820 action=accept direction= comment=net.routerd.net/v1alpha1/WireGuardInterface/wg-lab
### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
destroy set inet routerd_filter if_mgmt
destroy set inet routerd_filter if_wan
table inet routerd_filter {
  set if_lan { type ifname; elements = { "vtnet1" } }
  set if_mgmt { type ifname; elements = { "vtnet2" } }
  set if_wan { type ifname; elements = { "gif0", "vtnet0" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    iifname @if_mgmt jump mgmt_to_self
    iifname @if_wan jump wan_to_self
    counter log prefix "routerd firewall input deny " group 1 drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    iifname @if_lan oifname @if_mgmt jump lan_to_mgmt
    iifname @if_lan oifname @if_wan jump lan_to_wan
    iifname @if_mgmt oifname @if_lan jump mgmt_to_lan
    iifname @if_mgmt oifname @if_mgmt jump mgmt_to_mgmt
    iifname @if_mgmt oifname @if_wan jump mgmt_to_wan
    iifname @if_wan oifname @if_lan jump wan_to_lan
    iifname @if_wan oifname @if_mgmt jump wan_to_mgmt
    iifname @if_wan oifname @if_wan jump wan_to_wan
    counter log prefix "routerd firewall forward deny " group 1 drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
  chain lan_to_mgmt {
    counter log prefix "routerd firewall lan-to-mgmt deny " group 1 drop
  }
  chain lan_to_wan {
    counter accept
  }
  chain mgmt_to_self {
    counter accept
  }
  chain mgmt_to_lan {
    counter accept
  }
  chain mgmt_to_mgmt {
    counter accept
  }
  chain mgmt_to_wan {
    counter accept
  }
  chain wan_to_self {
    iifname "vtnet0" udp dport 41641 counter accept comment "net.routerd.net/v1alpha1/TailscaleNode/home"
    iifname "vtnet0" udp dport 68 counter accept comment "net.routerd.net/v1alpha1/DHCPv4Client/wan-dhcpv4"
    iifname "vtnet0" udp dport 546 counter accept comment "net.routerd.net/v1alpha1/DHCPv6PrefixDelegation/wan-pd"
    iifname "vtnet0" udp dport 51820 counter accept comment "net.routerd.net/v1alpha1/WireGuardInterface/wg-lab"
    counter log prefix "routerd firewall wan-to-self deny " group 1 drop
  }
  chain wan_to_lan {
    counter log prefix "routerd firewall wan-to-lan deny " group 1 drop
  }
  chain wan_to_mgmt {
    counter log prefix "routerd firewall wan-to-mgmt deny " group 1 drop
  }
  chain wan_to_wan {
    counter accept
  }
}
