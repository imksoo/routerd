    counter log prefix "routerd firewall lan-to-mgmt deny " group 1 drop
  }
  chain lan_to_wan {
    counter accept
  }
  chain mgmt_to_self {
    counter accept
  }
  chain mgmt_to_lan {
    counter accept
  }
  chain mgmt_to_mgmt {
