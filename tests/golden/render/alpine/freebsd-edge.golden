command_args="'daemon' '--socket' '/var/run/routerd/dpi-classifier/default.sock' '--ndpi-reader' '/usr/local/bin/ndpiReader'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dpi-classifier'
}
### openrc-routerd_firewall_logger
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_firewall_logger'
description='routerd firewall logger'
command='/usr/local/sbin/routerd-firewall-logger'
command_args="'daemon' '--path' '/var/db/routerd/firewall-logs.db' '--pflog-interface' 'pflog0' '--dpi-socket' '/var/run/routerd/dpi-classifier/default.sock'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd_dpi_classifier
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
### openrc-routerd_tailscale_home
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_tailscale_home'
description='routerd Tailscale node home'
command='/usr/bin/tailscale'
command_args="'up' '--hostname=freebsd-edge' '--advertise-routes=192.0.2.0/24' '--accept-dns=false'"

depend() {
	use net
	after tailscaled
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	'rc-service' 'tailscaled' 'start'
}
