add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "vtnet1" oifname { "gif0", "vtnet0" } ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size set 1414
    iifname "vtnet1" oifname { "gif0", "vtnet0" } meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size set 1394
  }
}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    oifname "gif0" ip saddr 192.0.2.0/24 masquerade
  }
}
### openrc-routerd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd'
description='routerd daemon'
command='/usr/local/sbin/routerd'
command_args="'serve'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/run/routerd/dns-resolver'
	checkpath -d -m 0755 '/run/routerd/pppoe-client'
	checkpath -d -m 0755 '/var/lib/routerd'
	checkpath -d -m 0755 '/var/log/routerd'
	'/usr/local/sbin/routerd' 'check'
}
### openrc-routerd_dnsmasq
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dnsmasq'
description='routerd managed dnsmasq DHCP service'
command='/usr/sbin/dnsmasq'
command_args="'--keep-in-foreground' '--user=root' '--group=root' '--conf-file=/usr/local/etc/routerd/dnsmasq.conf' '--pid-file=/run/routerd/dnsmasq.pid'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
### openrc-routerd_dpi_classifier
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dpi_classifier'
description='routerd DPI classifier'
command='/usr/local/sbin/routerd-dpi-classifier'
command_args="'daemon' '--socket' '/run/routerd/dpi-classifier/default.sock' '--engine' 'auto' '--ndpi-agent-socket' '/run/routerd/ndpi-agent/default.sock'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd_ndpi_agent
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dpi-classifier'
}
