### dnsmasq.conf
# Generated by routerd. Do not edit by hand.
dhcp-leasefile=/var/lib/routerd/dnsmasq/dnsmasq.leases
port=0
no-resolv
bind-dynamic
interface=vtnet1
except-interface=vtnet0
except-interface=vtnet2

dhcp-authoritative
dhcp-range=set:lan-dhcpv4,192.0.2.110,192.0.2.119,255.255.255.0,12h
dhcp-option=tag:lan-dhcpv4,option:router,192.0.2.1
dhcp-option=tag:lan-dhcpv4,option:dns-server,192.0.2.1
dhcp-host=02:00:00:00:01:50,192.0.2.115,printer,infinite
### openrc-routerd_dhcpv4_client_mgmt_dhcpv4
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dhcpv4_client_mgmt_dhcpv4'
description='routerd DHCPv4 client mgmt-dhcpv4'
command='/usr/local/sbin/routerd-dhcpv4-client'
command_args="'daemon' '--resource' 'mgmt-dhcpv4' '--interface' 'vtnet2'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/var/log/routerd'
}
