### openrc-routerd_dhcpv6_client_wan_pd
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dhcpv6_client_wan_pd'
description='routerd DHCPv6-PD client wan-pd'
command='/usr/local/sbin/routerd-dhcpv6-client'
command_args="'daemon' '--resource' 'wan-pd' '--interface' 'vtnet0' '--socket' '/run/routerd/dhcpv6-client/wan-pd.sock' '--lease-file' '/var/lib/routerd/dhcpv6-client/wan-pd/lease.json' '--event-file' '/var/lib/routerd/dhcpv6-client/wan-pd/events.jsonl'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv6-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv6-client/wan-pd'
	checkpath -d -m 0755 '/var/log/routerd'
}
### openrc-routerd_dnsmasq
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dnsmasq'
description='routerd managed dnsmasq DHCP service'
command='/usr/sbin/dnsmasq'
command_args="'--keep-in-foreground' '--user=root' '--group=root' '--conf-file=/usr/local/etc/routerd/dnsmasq.conf' '--pid-file=/run/routerd/dnsmasq.pid'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
	after routerd
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd'
	checkpath -d -m 0755 '/var/lib/routerd'
}
### openrc-routerd_dpi_classifier
