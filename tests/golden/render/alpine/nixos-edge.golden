add table inet routerd_mss
flush table inet routerd_mss
table inet routerd_mss {
  chain forward {
    type filter hook forward priority mangle; policy accept;
    iifname "ens19" oifname { "ds-lite-a", "ds-lite-b", "ds-lite-c", "ens18" } ip protocol tcp tcp flags syn / syn,rst tcp option maxseg size set 1414
    iifname "ens19" oifname { "ds-lite-a", "ds-lite-b", "ds-lite-c", "ens18" } meta nfproto ipv6 tcp flags syn / syn,rst tcp option maxseg size set 1394
  }
}
add table ip routerd_policy
flush table ip routerd_policy
table ip routerd_policy {
  chain prerouting {
    type filter hook prerouting priority mangle; policy accept;
    ip saddr 192.0.2.0/24 ip daddr 0.0.0.0/0 ct mark != 0x0 meta mark set ct mark
    ip saddr 192.0.2.0/24 ip daddr 0.0.0.0/0 ct mark 0x0 meta mark set jhash ip saddr . ip daddr mod 3 map { 0 : 0x100, 1 : 0x101, 2 : 0x102 }
    ip saddr 192.0.2.0/24 ip daddr 0.0.0.0/0 ct mark 0x0 ct mark set meta mark
  }
}
add table ip routerd_nat
flush table ip routerd_nat
table ip routerd_nat {
  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    oifname "ds-lite-a" ip saddr 192.0.2.0/24 meta l4proto { tcp, udp } masquerade to :1024-65535
    oifname "ds-lite-a" ip saddr 192.0.2.0/24 masquerade
    oifname "ds-lite-b" ip saddr 192.0.2.0/24 meta l4proto { tcp, udp } masquerade to :1024-65535
    oifname "ds-lite-b" ip saddr 192.0.2.0/24 masquerade
    oifname "ds-lite-c" ip saddr 192.0.2.0/24 meta l4proto { tcp, udp } masquerade to :1024-65535
    oifname "ds-lite-c" ip saddr 192.0.2.0/24 masquerade
  }
}
### openrc-routerd_dhcpv4_client_mgmt_dhcpv4
#!/sbin/openrc-run
# Generated by routerd. Do not edit by hand.

name='routerd_dhcpv4_client_mgmt_dhcpv4'
description='routerd DHCPv4 client mgmt-dhcpv4'
command='/usr/local/sbin/routerd-dhcpv4-client'
command_args="'daemon' '--resource' 'mgmt-dhcpv4' '--interface' 'ens20'"
command_background="yes"
pidfile="/run/routerd/openrc/${RC_SVCNAME}.pid"

depend() {
	use net
}

start_pre() {
	checkpath -d -m 0755 /run/routerd/openrc
	checkpath -d -m 0755 '/run/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/var/lib/routerd/dhcpv4-client'
	checkpath -d -m 0755 '/var/log/routerd'
}
