### firewall-holes.txt
lan-api-vip-vrrp from=lan to=self ifnames=vtnet1 proto=vrrp port=0 action=accept direction= comment=net.routerd.net/v1alpha1/VirtualAddress/lan-api-vip
### keepalived.conf
# Generated by routerd. Do not edit by hand.
global_defs {
  router_id routerd
}

vrrp_instance lan_api_vip {
  state BACKUP
  interface vtnet1
  virtual_router_id 70
  priority 150
  advert_int 1
  nopreempt
  unicast_peer {
    192.168.70.3
  }
  authentication {
    auth_type PASS
    auth_pass change-me
  }
  virtual_ipaddress {
    192.168.70.10/32 dev vtnet1
  }
}

### nftables-filter.nft
# Generated by routerd. Do not edit by hand.
add table inet routerd_filter
flush table inet routerd_filter
destroy set inet routerd_filter if_lan
table inet routerd_filter {
  comment "routerd.owner=routerd routerd.generation=1"
  set if_lan { type ifname; elements = { "vtnet1" } }
  chain input {
    type filter hook input priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    iifname "lo" counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan jump lan_to_self
    counter drop
  }
  chain forward {
    type filter hook forward priority filter; policy drop;
    ct state invalid counter drop
    ct state { established, related } counter accept
    meta l4proto ipv6-icmp counter accept
    iifname @if_lan oifname @if_lan jump lan_to_lan
    counter drop
  }
  chain lan_to_self {
    counter accept
  }
  chain lan_to_lan {
    counter accept
  }
}
