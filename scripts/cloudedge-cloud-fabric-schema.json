{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/imksoo/routerd/scripts/cloudedge-cloud-fabric-schema.json",
  "title": "routerd CloudEdge SAM cloud fabric evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "testId",
    "phase",
    "provider",
    "result",
    "observedAt",
    "evidencePath",
    "normalized",
    "checks",
    "raw"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "testId": { "type": "string", "pattern": "^[0-9]{8}-[0-9]{4}-[A-Z0-9-]+-[0-9]{2}$" },
    "phase": { "type": "string", "const": "CF" },
    "provider": { "type": "string", "enum": ["aws", "azure", "oci"] },
    "result": { "type": "string", "enum": ["PASS", "PARTIAL", "NOT-RUN"] },
    "reason": { "type": "string" },
    "observedAt": { "type": "string", "format": "date-time" },
    "evidencePath": { "type": "string", "minLength": 1 },
    "normalized": { "$ref": "#/definitions/normalized" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/check" }
    },
    "raw": { "type": "object" }
  },
  "definitions": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "result", "reason"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "enum": ["PASS", "PARTIAL", "NOT-RUN"] },
        "reason": { "type": "string" }
      }
    },
    "normalized": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captureAddress",
        "primaryAddress",
        "secondaryAddresses",
        "forwardingEnabled",
        "localRouteObserved",
        "routeTargets",
        "securityRefs",
        "flowLogRefs",
        "providerSpecific"
      ],
      "properties": {
        "captureAddress": { "type": ["string", "null"] },
        "primaryAddress": { "type": ["string", "null"] },
        "secondaryAddresses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forwardingEnabled": { "type": ["boolean", "null"] },
        "localRouteObserved": { "type": ["boolean", "null"] },
        "routeTargets": {
          "type": "array",
          "items": { "$ref": "#/definitions/routeTarget" }
        },
        "securityRefs": {
          "type": "array",
          "items": { "$ref": "#/definitions/namedRef" }
        },
        "flowLogRefs": {
          "type": "array",
          "items": { "$ref": "#/definitions/namedRef" }
        },
        "providerSpecific": { "type": "object" }
      }
    },
    "routeTarget": {
      "type": "object",
      "additionalProperties": true,
      "required": ["prefix", "target"],
      "properties": {
        "prefix": { "type": "string" },
        "target": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "namedRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "result": { "const": "NOT-RUN" } }, "required": ["result"] },
      "then": { "required": ["reason"], "properties": { "reason": { "minLength": 1 } } }
    },
    {
      "if": { "properties": { "result": { "const": "PARTIAL" } }, "required": ["result"] },
      "then": { "required": ["reason"], "properties": { "reason": { "minLength": 1 } } }
    }
  ]
}
