{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/imksoo/routerd/scripts/cloudedge-protocol-result-schema.json",
  "title": "routerd CloudEdge protocol transparency probe result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "pairs", "summary"],
  "properties": {
    "status": { "$ref": "#/definitions/checkState" },
    "pairs": {
      "type": "array",
      "items": { "$ref": "#/definitions/pairResult" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "checks"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ftpActive", "ftpPassive", "nfs", "rpc", "bulkTransfer", "pmtu", "sourceIpPreserved", "noNat"],
          "properties": {
            "ftpActive": { "$ref": "#/definitions/checkState" },
            "ftpPassive": { "$ref": "#/definitions/checkState" },
            "nfs": { "$ref": "#/definitions/checkState" },
            "rpc": { "$ref": "#/definitions/checkState" },
            "bulkTransfer": { "$ref": "#/definitions/checkState" },
            "pmtu": { "$ref": "#/definitions/checkState" },
            "sourceIpPreserved": { "$ref": "#/definitions/checkState" },
            "noNat": { "$ref": "#/definitions/checkState" }
          }
        }
      }
    }
  },
  "definitions": {
    "checkState": {
      "type": "string",
      "enum": ["pass", "fail", "skip", "na"]
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "pairResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client", "server", "bytesRequested", "checks", "details", "result"],
      "properties": {
        "client": { "type": "string", "minLength": 1 },
        "server": { "type": "string", "minLength": 1 },
        "bytesRequested": { "type": "integer", "minimum": 1 },
        "result": { "$ref": "#/definitions/checkState" },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["setup", "ftpActive", "ftpPassive", "nfs", "rpc", "bulkTransfer", "pmtu", "sourceIpPreserved", "noNat"],
          "properties": {
            "setup": { "$ref": "#/definitions/checkState" },
            "ftpActive": { "$ref": "#/definitions/checkState" },
            "ftpPassive": { "$ref": "#/definitions/checkState" },
            "nfs": { "$ref": "#/definitions/checkState" },
            "rpc": { "$ref": "#/definitions/checkState" },
            "bulkTransfer": { "$ref": "#/definitions/checkState" },
            "pmtu": { "$ref": "#/definitions/checkState" },
            "sourceIpPreserved": { "$ref": "#/definitions/checkState" },
            "noNat": { "$ref": "#/definitions/checkState" }
          }
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "required": ["setup", "ftpActive", "ftpPassive", "nfs", "rpc", "bulkTransfer", "pmtu", "sourceIpPreserved", "noNat"],
          "properties": {
            "setup": { "$ref": "#/definitions/details" },
            "ftpActive": { "$ref": "#/definitions/details" },
            "ftpPassive": { "$ref": "#/definitions/details" },
            "nfs": { "$ref": "#/definitions/details" },
            "rpc": { "$ref": "#/definitions/details" },
            "bulkTransfer": { "$ref": "#/definitions/details" },
            "pmtu": { "$ref": "#/definitions/pmtuDetails" },
            "sourceIpPreserved": { "$ref": "#/definitions/details" },
            "noNat": { "$ref": "#/definitions/details" }
          }
        }
      }
    },
    "mtuEvidenceValue": {
      "anyOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "const": "unknown" }
      ]
    },
    "pmtuDetails": {
      "type": "object",
      "additionalProperties": true,
      "required": ["overlay_mtu", "route_mtu", "route_advmss", "mss_clamp", "effective_mss_clamp"],
      "properties": {
        "overlay_iface": { "type": "string" },
        "overlay_mtu": { "$ref": "#/definitions/mtuEvidenceValue" },
        "overlay_mtu_reason": { "type": "string", "minLength": 1 },
        "route_mtu": { "$ref": "#/definitions/mtuEvidenceValue" },
        "route_mtu_reason": { "type": "string", "minLength": 1 },
        "route_advmss": { "$ref": "#/definitions/mtuEvidenceValue" },
        "route_advmss_reason": { "type": "string", "minLength": 1 },
        "mss_clamp": { "$ref": "#/definitions/mtuEvidenceValue" },
        "mss_clamp_reason": { "type": "string", "minLength": 1 },
        "effective_mss_clamp": { "$ref": "#/definitions/mtuEvidenceValue" },
        "effective_mss_clamp_reason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "overlay_mtu": { "const": "unknown" } }, "required": ["overlay_mtu"] },
          "then": { "required": ["overlay_mtu_reason"] }
        },
        {
          "if": { "properties": { "route_mtu": { "const": "unknown" } }, "required": ["route_mtu"] },
          "then": { "required": ["route_mtu_reason"] }
        },
        {
          "if": { "properties": { "route_advmss": { "const": "unknown" } }, "required": ["route_advmss"] },
          "then": { "required": ["route_advmss_reason"] }
        },
        {
          "if": { "properties": { "mss_clamp": { "const": "unknown" } }, "required": ["mss_clamp"] },
          "then": { "required": ["mss_clamp_reason"] }
        },
        {
          "if": { "properties": { "effective_mss_clamp": { "const": "unknown" } }, "required": ["effective_mss_clamp"] },
          "then": { "required": ["effective_mss_clamp_reason"] }
        }
      ]
    }
  }
}
